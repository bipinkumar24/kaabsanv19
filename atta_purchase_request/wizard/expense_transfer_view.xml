<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="purchase_request_expense_transfer_wizard" model="ir.ui.view">
            <field name="name">purchase_request_expense_transfer_wizard</field>
            <field name="model">expense.transfer.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="picking_type_id" required="1"/>
                                <field name="picking_type_code" invisible="1"/>
                                <field name="location_id" required="1"/>
                                <field name="location_dest_id"/>
                                <field name="employee_id" required="1"/>
                            </group>
                            <group>
                                <field name="property_stock_account_output_categ_id" required="1"/>
                                <field name="type_data"/>
                                <field name="fleet_id" invisible="type_data == 'computer'" required="type_data == 'car'"/>
                                <field name="odometer" invisible="type_data == 'computer'"/>
                                <field name="equipment_id" invisible="type_data == 'car'" required="type_data == 'computer'"/>
                            </group>
                        </group>
                    </sheet>
                    <footer class="oe_edit_only">
                        <button name="action_create_expense_transfer" type="object"
                                string="Create Expense Transfer"
                                class="oe_highlight"/>
                        <button string="Cancel" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
