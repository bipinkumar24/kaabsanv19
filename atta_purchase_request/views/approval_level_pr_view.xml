<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record model="ir.ui.view" id="approval_level_tree_view_pr">
            <field name="name">approval.level.tree.pr</field>
            <field name="model">approval.level.pr</field>
            <field name="arch" type="xml">
                <tree string="Approval Level Form" editable="bottom">
                    <field name="name" />
                    <field name="level" />
                    <field name="is_last_approval" />
                    <field name="is_reject" />
                    <field name="is_full_field"/>
                    <field name="approval_user_ids" widget="many2many_tags" required="not is_reject"/>
                    <field name="group_ids" widget="many2many_tags"/>
                    <field name="fields_ids" widget="many2many_tags" domain="[('model', '=', 'purchase.request')]"/>
                    <field name="display_message"/>
                </tree>
            </field>
        </record>
        <record model="ir.ui.view" id="approval_level_form_view_pr">
            <field name="name">approval.level.form.pr</field>
            <field name="model">approval.level.pr</field>
            <field name="arch" type="xml">
                <form string="Approval Level Form">
                    <sheet>
                        <group>
                            <field name="name" required="1" />
                            <field name="level" required="1" />
                            <field name="is_last_approval" />
                            <field name="is_reject" />
                            <field name="is_full_field"/>
                            <field name="approval_user_ids" widget="many2many_tags" required="not is_reject" />
                            <field name="group_ids" widget="many2many_tags"/>
                            <field name="display_message"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_approval_level_pr" model="ir.actions.act_window">
            <field name="name">Approval Level of Purchase Request</field>
            <field name="res_model">approval.level.pr</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_mode">tree,form</field>
        </record>
        <menuitem id="menu_approval_level_pr" parent="atta_purchase_request.purchase_request_menu_config"
                  name="Purchase Request Approval Level" action="action_approval_level_pr"
                  groups="base.group_system" sequence="4" />
    </data>
</odoo>
