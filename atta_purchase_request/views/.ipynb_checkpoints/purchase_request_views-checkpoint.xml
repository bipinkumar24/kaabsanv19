<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="purchase_request_view_tree" model="ir.ui.view">
            <field name="name">purchase.request.view.tree</field>
            <field name="model">purchase.request</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="create_uid"/>
                    <field name="request_deliver_date"/>
                    <field name="schedule_date"/>
                    <field name="user_id"/>
                    <field name="po_creation_state"/>
                    <field name="next_approval_id"/>
                </tree>
            </field>
        </record>

        <record id="purchase_request_view_form" model="ir.ui.view">
            <field name="name">purchase.request.view.form</field>
            <field name="model">purchase.request</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_submit"
                                type="object"
                                string="Submit"
                                class="oe_highlight"
                                states="draft"
                                groups="atta_purchase_request.purchase_request_group_user"
                        />
                        <button name="action_first_approve"
                                type="object"
                                string="Approve"
                                class="oe_highlight"
                                states="first"
                                groups="atta_purchase_request.purchase_request_group_first_approval"
                        />
                        <button name="action_second_approve"
                                type="object"
                                string="Approve"
                                class="oe_highlight"
                                states="second"
                                groups="atta_purchase_request.purchase_request_group_second_approval"
                        />
                        <button name="action_third_approve"
                                type="object"
                                string="Approve"
                                class="oe_highlight"
                                states="third"
                                groups="atta_purchase_request.purchase_request_group_third_approval"
                        />
                        <button name="action_4th_approve"
                                type="object"
                                string="Approve"
                                class="oe_highlight"
                                states="fourth"
                                groups="atta_purchase_request.purchase_request_group_4th_approval"
                        />
                        <button name="action_done"
                                type="object"
                                string="Done"
                                class="oe_highlight"
                                states="final"
                                groups="atta_purchase_request.purchase_request_group_second_approval"
                        />
                        <button name="action_unlock"
                                type="object"
                                string="Unlock"
                                states="done"
                                groups="atta_purchase_request.purchase_request_group_second_approval"
                        />
                        <button name="action_cancel"
                                type="object"
                                string="Cancel"
                                states="draft,first,second,third,fourth"
                                groups="atta_purchase_request.purchase_request_group_user"
                        />
                        <button name="action_cancel"
                                type="object"
                                string="Cancel"
                                states="final"
                                groups="atta_purchase_request.purchase_request_group_second_approval"
                        />
                        <button name="action_draft"
                                type="object"
                                string="Set to Draft"
                                states="canceled"
                        />
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_line"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-align-justify"
                                    attrs="{'invisible': [('line_count', '=', 0)]}"
                                    groups="atta_purchase_request.purchase_request_group_second_approval"
                            >
                                <field name="line_count"
                                       widget="statinfo"
                                       string="PR Lines"
                                />
                            </button>
                            <button name="action_view_order"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-shopping-cart"
                                    attrs="{'invisible': [('order_count', '=', 0)]}"
                                    groups="atta_purchase_request.purchase_request_group_second_approval"
                            >
                                <field name="order_count"
                                       widget="statinfo"
                                       string="Purchase Orders"
                                />
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="create_uid"/>
                                <field name="department_id"
                                       attrs="{'readonly': [('state', '!=', 'draft')]}"
                                />
                                <field name="min_request_deliver_date"
                                       invisible="1"/>
                                <label for="request_deliver_date"/>
                                <div name="request_deliver_date">
                                    <field name="request_deliver_date"
                                           attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                                    <button name="action_set_request_deliver_date_to_lines"
                                            type="object"
                                            string=" Set Date to All Request Line"
                                            icon="fa-calendar"
                                            colspan="2"
                                            class="btn-link"
                                            attrs="{'invisible': ['|', ('request_deliver_date', '=', False), ('state', '!=', 'draft')]}"
                                            groups="atta_purchase_request.purchase_request_group_user"
                                    />
                                </div>
                                <field name="min_schedule_date" invisible="1"/>
                                <label for="schedule_date"/>
                                <div name="schedule_date">
                                    <field name="schedule_date"
                                           attrs="{
                                                'readonly': [
                                                    ('state', 'not in', ['draft', 'first', 'second']),
                                                ],
                                            }"
                                    />
                                    <button name="action_set_schedule_date_to_lines"
                                            type="object"
                                            string=" Set Date to All Request Line"
                                            icon="fa-calendar"
                                            colspan="2"
                                            class="btn-link"
                                            attrs="{'invisible': ['|', ('schedule_date', '=', False), ('state', 'not in', ['draft', 'first', 'second'])]}"
                                            groups="atta_purchase_request.purchase_request_group_second_approval"
                                    />
                                </div>
                                <field name="user_id"
                                       attrs="{'readonly': [('state', 'not in', ['draft', 'first', 'second'])]}"/>
                            </group>
                            <group>
                                <field name="description"
                                       attrs="{'readonly': [('state', '!=', 'draft')]}"
                                />
                                <field name="note"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Request Lines">
                                <field name="has_access_right" invisible="1"/>
                                <field name="line_ids"
                                       attrs="{
                                            'readonly': [
                                                ('state', 'not in', ['draft', 'first', 'second', 'third', 'fourth']),
                                            ]
                                        }"
                                       context="{
                                            'default_request_deliver_date': request_deliver_date,
                                            'default_schedule_date': schedule_date,
                                       }"
                                >
                                    <tree editable="bottom"
                                          decoration-muted="quantity == 0"
                                          decoration-success="po_creation_state == 'fully' or request_state == 'done'"
                                          decoration-danger="po_creation_state != 'fully' and request_state == 'final' and quantity > 0"
                                    >
                                        <field name="request_state"
                                               invisible="1"/>
                                        <field name="po_creation_state"
                                               invisible="1"/>
                                        <field name="is_edited" invisible="1"/>
                                        <field name="is_last_level" invisible="1"/>
                                        <field name="product_id"
                                               attrs="{
                                                    'readonly': [
                                                       '|',
                                                       '|',
                                                       ('is_edited', '=', False),
                                                       ('parent.state', 'not in', ['draft', 'first', 'second', 'third', 'fourth']),
                                                       '&amp;',
                                                       ('parent.has_access_right', '=', False),
                                                       ('parent.state', 'in', ['second', 'third', 'fourth']),
                                                   ],
                                                   'required': [
                                                       ('parent.state', 'in', ['second', 'third', 'fourth']),
                                                       ('quantity', '>', 0),
                                                   ],
                                                   'invisible': [('is_last_level', '=', True)]
                                               }"
                                               options="{
                                                    'no_quick_create':1,
                                               }"
                                               context="{
                                                    'form_view_ref': 'product.product_template_only_form_view',
                                               }"
                                               optional="show"

                                        />
                                        <field name="description"
                                               attrs="{
                                                    'readonly': [
                                                       '|',
                                                       '|',
                                                       ('is_edited', '=', False),
                                                       ('parent.state', 'not in', ['draft', 'first', 'second', 'third', 'fourth']),
                                                       '&amp;',
                                                       ('parent.has_access_right', '=', False),
                                                       ('parent.state', 'in', ['second', 'third', 'fourth']),
                                                    ],
                                               }"
                                               optional="show"
                                        />
                                        <field name="request_deliver_date"
                                               force_save="1"
                                               attrs="{'readonly': [('parent.state', '!=', 'draft')]}"
                                               optional="show"
                                        />
                                        <field name="schedule_date"
                                               force_save="1"
                                               attrs="{
                                                    'readonly': [
                                                        ('parent.state', 'not in', ['draft', 'first', 'second', 'third', 'fourth']),
                                                    ],
                                                    'required': [
                                                        ('parent.state', 'in', ['second', 'third', 'fourth']),
                                                        ('quantity', '>', 0),
                                                    ]
                                                }"
                                               optional="show"
                                        />
                                        <field name="request_qty"
                                               force_save="1"
                                               sum="Sum"
                                               attrs="{'readonly': [('parent.state', 'not in', ['draft', 'first'])]}"
                                               optional="show"
                                        />
                                        <field name="quantity"
                                               force_save="1"
                                               sum="Sum"
                                               attrs="{
                                                    'readonly': [
                                                        '|',
                                                        ('parent.has_access_right', '=', False),
                                                        ('parent.state', 'not in', ['second', 'third', 'fourth']),
                                                    ]
                                                }"
                                               optional="show"
                                        />
                                        <field name="partner_id"
                                               force_save="1"
                                               attrs="{
                                                'readonly': [
                                                        ('parent.state', 'not in', ['draft', 'first', 'second', 'third', 'fourth']),
                                                    ]
                                                }"
                                               context="{'default_supplier_rank': 1}"
                                               optional="show"
                                        />
                                        <field name="currency_id"
                                               force_save="1"
                                               attrs="{
                                                'readonly': [
                                                        ('parent.state', 'not in', ['draft', 'first', 'second', 'third', 'fourth']),
                                                    ]
                                                }"
                                               optional="show"
                                        />
                                        <field name="request_currency_id"
                                               invisible="1"
                                        />
                                        <field name="price_unit_currency"
                                               attrs="{
                                                'readonly': [
                                                        ('parent.state', 'not in', ['draft', 'first', 'second', 'third', 'fourth']),
                                                    ]
                                                }"
                                               groups="atta_purchase_request.purchase_request_group_second_approval"
                                               optional="hide"
                                        />
                                        <field name="price_unit"
                                               groups="atta_purchase_request.purchase_request_group_second_approval"
                                               optional="hide"
                                        />
                                        <field name="uom_id"
                                               attrs="{'readonly': [('parent.state', 'not in', ['draft', 'first', 'second'])]}"
                                               optional="show"
                                        />
                                        <field name="tax_ids"
                                               widget="many2many_tags"
                                               attrs="{'readonly': [('parent.state', 'not in', ['draft', 'first', 'second'])]}"
                                               optional="hide"
                                        />
                                        <field name="price_total"
                                               widget="monetary"
                                               options="{'currency_field': 'request_currency_id'}"
                                               groups="atta_purchase_request.purchase_request_group_second_approval"
                                               optional="hide"
                                        />
                                        <field name="purchased_qty"
                                               sum="Sum"
                                               optional="show"
                                        />
                                        <field name="note" optional="show"/>
                                    </tree>
                                </field>
                                <group class="oe_subtotal_footer oe_right"
                                       groups="atta_purchase_request.purchase_request_group_second_approval">
                                    <field name="currency_id" invisible="1"/>
                                    <field name="amount_untaxed"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="amount_tax" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <div class="oe_subtotal_footer_separator oe_inline">
                                        <label for="amount_total"
                                               style="font-weight: bold;"/>
                                    </div>
                                    <field name="amount_total" nolabel="1"
                                           class="oe_subtotal_footer_separator"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </page>
                            <page string="Currency Rate">
                                <field name="currency_rate_ids">
                                    <tree editable="bottom" create="0"
                                          delete="0">
                                        <field name="currency_id"
                                               force_save="1"/>
                                        <field name="rate"
                                               attrs="{'readonly': [(
                                                    'parent.state',
                                                    'not in',
                                                    ['draft', 'first', 'second']
                                                )]}"
                                        />
                                    </tree>
                                </field>
                            </page>
                            <page string="Other Information">
                                <group>
                                    <group string="Purchasing" name="purchase">
                                        <field name="po_creation_state"/>
                                    </group>
                                    <group string="Company"
                                           groups="base.group_multi_company"
                                    >
                                        <field name="company_id"
                                               attrs="{'readonly': [('state', '!=', 'draft')]}"
                                               options="{'no_create_edit': 1}"
                                        />
                                        <field name="currency_id"/>
                                    </group>
                                </group>
                                <group string="Related Users">
                                    <group>
                                        <field name="create_date"/>
                                        <field name="submit_date"
                                               attrs="{'invisible': [('submit_date', '=', False)]}"/>
                                        <field name="first_approve_uid"
                                               attrs="{'invisible': [('first_approve_uid', '=', False)]}"/>
                                        <field name="first_approve_date"
                                               attrs="{'invisible': [('first_approve_date', '=', False)]}"/>
                                        <field name="second_approve_uid"
                                               attrs="{'invisible': [('second_approve_uid', '=', False)]}"/>
                                        <field name="second_approve_date"
                                               attrs="{'invisible': [('second_approve_date', '=', False)]}"/>
                                        <field name="third_approve_uid"
                                               attrs="{'invisible': [('third_approve_uid', '=', False)]}"/>
                                        <field name="third_approve_date"
                                               attrs="{'invisible': [('third_approve_date', '=', False)]}"/>
                                    </group>
                                    <group>
                                        <field name="fourth_approve_uid"
                                               attrs="{'invisible': [('fourth_approve_uid', '=', False)]}"/>
                                        <field name="fourth_approve_date"
                                               attrs="{'invisible': [('fourth_approve_date', '=', False)]}"/>
                                        <field name="cancel_uid"
                                               attrs="{'invisible': [('cancel_uid', '=', False)]}"/>
                                        <field name="cancel_date"
                                               attrs="{'invisible': [('cancel_date', '=', False)]}"/>
                                        <field name="done_uid"
                                               attrs="{'invisible': [('done_uid', '=', False)]}"/>
                                        <field name="done_date"
                                               attrs="{'invisible': [('done_date', '=', False)]}"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"
                               widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"
                               options="{'post_refresh': 'recipients'}"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="purchase_request_view_search" model="ir.ui.view">
            <field name="name">purchase.request.view.search</field>
            <field name="model">purchase.request</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="create_uid"/>
                    <field name="user_id"/>
                    <group>
                        <filter string="Buyer"
                                name="group_user_id"
                                context="{'group_by': 'user_id'}"
                        />
                        <filter string="Requester"
                                name="group_create_uid"
                                context="{'group_by': 'create_uid'}"
                        />
                        <filter string="Status"
                                name="group_state"
                                context="{'group_by': 'state'}"
                        />
                    </group>
                </search>
            </field>
        </record>

        <record id="purchase_request_action" model="ir.actions.act_window">
            <field name="name">Purchase/Stock Requests / Expense Transfer</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">purchase.request</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
