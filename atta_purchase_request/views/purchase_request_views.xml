<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="purchase_request_view_tree" model="ir.ui.view">
            <field name="name">purchase.request.view.tree</field>
            <field name="model">purchase.request</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="create_uid"/>
                    <field name="request_deliver_date"/>
                    <field name="schedule_date"/>
                    <field name="user_id"/>
                    <field name="po_creation_state"/>
                    <field name="next_approval_id"/>
                </list>
            </field>
        </record>

        <record id="purchase_request_view_form" model="ir.ui.view">
            <field name="name">purchase.request.view.form</field>
            <field name="model">purchase.request</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="is_button" invisible="1"/>
                        <field name="is_last_level" invisible="1"/>
                        <field name="rfq_show" invisible="1"/>
                        <field name="state" invisible="1"/>
                        <field name="is_show_button_type" invisible="1"/>
                        <field name="next_approval_user_ids" invisible="1"/>
                        <field name="show_rfq_button" invisible="1"/>
                        <field name="show_allocation_button" invisible="1"/>
                        <field name="show_expense_button" invisible="1"/>
                        <button name="action_approve" type="object" invisible="not is_button"
                                string="Next Stage / Reject" class="oe_highlight"/>
                        <field name="next_approval_id" widget="statusbar"/>
                        <button name="action_create_rfq" type="object"
                                invisible="not is_show_button_type or not show_rfq_button"
                                string="Create Rfq" class="oe_highlight"/>
                        <button name="action_create_allocation" type="object"
                                invisible="not is_show_button_type or not show_allocation_button"
                                string="Create Allocation" class="oe_highlight"/>
                        <button name="action_create_expense" type="object"
                                invisible="not is_show_button_type or not show_expense_button"
                                string="Create Expense Transfer" class="oe_highlight"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_line"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-align-justify"
                                    invisible="line_count == 0"
                                    groups="atta_purchase_request.purchase_request_group_second_approval">
                                <field name="line_count" widget="statinfo" string="Lines"/>
                            </button>
                            <button name="action_view_order"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-shopping-cart"
                                    invisible="order_count == 0"
                                    groups="atta_purchase_request.purchase_request_group_second_approval">
                                <field name="order_count" widget="statinfo" string="Purchase Orders"/>
                            </button>
                            <button name="action_view_allocation"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-shopping-cart"
                                    invisible="allocation_count == 0">
                                <field name="allocation_count" widget="statinfo" string="Allocation"/>
                            </button>
                            <button name="action_view_expense"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-truck"
                                    invisible="expense_count == 0">
                                <field name="expense_count" widget="statinfo" string="Expense"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="create_uid"/>
                                <field name="department_id"/>
                                <field name="min_request_deliver_date" invisible="1"/>
                                <label for="request_deliver_date"/>
                                <div name="request_deliver_date">
                                    <field name="request_deliver_date"/>
                                    <button name="action_set_request_deliver_date_to_lines"
                                            type="object"
                                            string=" Set Date to All Request Line"
                                            icon="fa-calendar"
                                            colspan="2"
                                            class="btn-link"
                                            invisible="not request_deliver_date"
                                            groups="atta_purchase_request.purchase_request_group_user"/>
                                </div>
                                <field name="min_schedule_date" invisible="1"/>
                                <label for="schedule_date"/>
                                <div name="schedule_date">
                                    <field name="schedule_date"/>
                                    <button name="action_set_schedule_date_to_lines"
                                            type="object"
                                            string=" Set Date to All Request Line"
                                            icon="fa-calendar"
                                            colspan="2"
                                            class="btn-link"
                                            invisible="not schedule_date"
                                            groups="atta_purchase_request.purchase_request_group_second_approval"/>
                                </div>
                                <field name="user_id"/>
                                <field name="location_dest_id"/>
                            </group>
                            <group>
                                <field name="description"/>
                                <field name="note"/>
                                <field name="readonly_field" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Request Lines">
                                <field name="has_access_right" invisible="1"/>
                                <field name="line_ids"
                                       context="{
                                            'default_request_deliver_date': request_deliver_date,
                                            'default_schedule_date': schedule_date,
                                       }">
                                    <list editable="bottom"
                                          decoration-muted="quantity == 0"
                                          decoration-success="po_creation_state == 'fully' or request_state == 'done'"
                                          decoration-danger="po_creation_state != 'fully' and request_state == 'final' and quantity > 0">
                                        <field name="request_state" invisible="1"/>
                                        <field name="po_creation_state" invisible="1"/>
                                        <field name="is_edited" invisible="1"/>
                                        <field name="is_first" invisible="1"/>
                                        <field name="product_id"
                                               readonly="not parent.readonly_field"
                                               required="quantity > 0 and not is_first"
                                               invisible="is_first"
                                               options="{'no_quick_create': 1}"
                                               context="{'form_view_ref': 'product.product_template_only_form_view'}"
                                               optional="show"/>
                                        <field name="description"
                                               readonly="not is_edited"
                                               optional="show"/>
                                        <field name="request_deliver_date"
                                               force_save="1"
                                               optional="show"/>
                                        <field name="schedule_date"
                                               force_save="1"
                                               required="quantity > 0"
                                               optional="show"/>
                                        <field name="request_qty"
                                               force_save="1"
                                               sum="Sum"
                                               optional="show"/>
                                        <field name="quantity"
                                               force_save="1"
                                               sum="Sum"
                                               optional="show"/>
                                        <field name="partner_id"
                                               force_save="1"
                                               context="{'default_supplier_rank': 1}"
                                               optional="show"/>
                                        <field name="currency_id"
                                               force_save="1"
                                               optional="show"/>
                                        <field name="request_currency_id" invisible="1"/>
                                        <field name="price_unit_currency"
                                               groups="atta_purchase_request.purchase_request_group_second_approval"
                                               optional="hide"/>
                                        <field name="price_unit"
                                               groups="atta_purchase_request.purchase_request_group_second_approval"
                                               optional="hide"/>
                                        <field name="uom_id" optional="show"/>
                                        <field name="tax_ids"
                                               widget="many2many_tags"
                                               optional="hide"/>
                                        <field name="price_total"
                                               widget="monetary"
                                               options="{'currency_field': 'request_currency_id'}"
                                               groups="atta_purchase_request.purchase_request_group_second_approval"
                                               optional="hide"/>
                                        <field name="purchased_qty" sum="Sum" optional="show"/>
                                        <field name="note" optional="show"/>
                                        <field name="rfq_create" readonly="not parent.readonly_field"/>
                                        <field name="allocation_create" readonly="not parent.readonly_field"/>
                                        <field name="expense_create" readonly="not parent.readonly_field"/>
                                    </list>
                                </field>
                                <group class="oe_subtotal_footer oe_right"
                                       groups="atta_purchase_request.purchase_request_group_second_approval">
                                    <field name="currency_id" invisible="1"/>
                                    <field name="amount_untaxed"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <field name="amount_tax"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                    <div class="oe_subtotal_footer_separator oe_inline">
                                        <label for="amount_total" style="font-weight: bold;"/>
                                    </div>
                                    <field name="amount_total"
                                           nolabel="1"
                                           class="oe_subtotal_footer_separator"
                                           widget="monetary"
                                           options="{'currency_field': 'currency_id'}"/>
                                </group>
                            </page>
                            <page string="Currency Rate">
                                <field name="currency_rate_ids">
                                    <list editable="bottom" create="0" delete="0">
                                        <field name="currency_id" force_save="1"/>
                                        <field name="rate"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Other Information">
                                <group>
                                    <group string="Purchasing" name="purchase">
                                        <field name="po_creation_state"/>
                                    </group>
                                    <group string="Company" groups="base.group_multi_company">
                                        <field name="company_id" options="{'no_create_edit': 1}"/>
                                        <field name="currency_id"/>
                                    </group>
                                </group>
                                <group string="Related Users">
                                    <group>
                                        <field name="create_date"/>
                                        <field name="submit_date" invisible="not submit_date"/>
                                        <field name="first_approve_uid" invisible="not first_approve_uid"/>
                                        <field name="first_approve_date" invisible="not first_approve_date"/>
                                        <field name="second_approve_uid" invisible="not second_approve_uid"/>
                                        <field name="second_approve_date" invisible="not second_approve_date"/>
                                        <field name="third_approve_uid" invisible="not third_approve_uid"/>
                                        <field name="third_approve_date" invisible="not third_approve_date"/>
                                    </group>
                                    <group>
                                        <field name="fourth_approve_uid" invisible="not fourth_approve_uid"/>
                                        <field name="fourth_approve_date" invisible="not fourth_approve_date"/>
                                        <field name="cancel_uid" invisible="not cancel_uid"/>
                                        <field name="cancel_date" invisible="not cancel_date"/>
                                        <field name="done_uid" invisible="not done_uid"/>
                                        <field name="done_date" invisible="not done_date"/>
                                    </group>
                                </group>
                            </page>
                            <page name="remarks" string="Remarks">
                                <field name="remark_ids" readonly="1">
                                    <list>
                                        <field name="user_id" readonly="1"/>
                                        <field name="name" readonly="1"/>
                                        <field name="remark_datettime" readonly="1"/>
                                        <field name="consumed_hours" readonly="1"/>
                                        <field name="from_stage_id" readonly="1"/>
                                        <field name="to_stage_id" readonly="1"/>
                                        <field name="remark_type" readonly="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter
                        reload_on_post="True"
                        reload_on_attachment="True"
                        reload_on_follower="True"
                        open_attachments="True"
                    />
                </form>
            </field>
        </record>

        <record id="purchase_request_view_search" model="ir.ui.view">
            <field name="name">purchase.request.view.search</field>
            <field name="model">purchase.request</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="create_uid"/>
                    <field name="user_id"/>
                    <group>
                        <filter string="Buyer"
                                name="group_user_id"
                                context="{'group_by': 'user_id'}"/>
                        <filter string="Requester"
                                name="group_create_uid"
                                context="{'group_by': 'create_uid'}"/>
                        <filter string="Status"
                                name="group_state"
                                context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="purchase_request_action" model="ir.actions.act_window">
            <field name="name">Purchase/Stock Requests / Expense Transfer</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">purchase.request</field>
            <field name="view_mode">tree,form</field>
        </record>

    </data>
</odoo>
