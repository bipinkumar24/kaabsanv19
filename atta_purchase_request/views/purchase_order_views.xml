<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="purchase_order_search_inherit_kaabsab" model="ir.ui.view">
            <field name="name">purchase.order.list.select.inherit.kaabsab</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='origin']" position="after">
                    <field name="tag_name"/>
                </xpath>
                <xpath expr="//filter[@name='order_date']" position="after">
                    <filter string="Tags" name="tags" domain="[]" context="{'group_by': 'tag_name'}"/>
                </xpath>
            </field>
        </record>

        <record id="group_procurement" model="res.groups">
            <field name="name">Procurement Manager </field>
        </record>
        <record id="group_general" model="res.groups">
            <field name="name">General Manager</field>
        </record>

        <record id="purchase_order_form" model="ir.ui.view">
            <field name="name">purchase.order.form</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">

                <xpath expr="//button[@name='action_view_invoice']" position="after">
                    <button name="action_view_request_line"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-pencil-square-o"
                            invisible="request_line_count == 0"
                    >
                        <field name="request_line_count"
                               widget="statinfo"
                               string="Request Lines"
                        />
                    </button>

                </xpath>
                <xpath expr="//header" position="inside">
                    <button name="action_submit" type="object" class="oe_highlight"
                            invisible="state != 'initial'"
                            string="Submit For Confirmation" data-hotkey="w"/>
                    <button name="action_procurement" type="object" class="oe_highlight"
                            invisible="state != 'procurement'"
                            groups="atta_purchase_request.group_procurement"
                            string="Approve by Procurement Manager" data-hotkey="w"/>
                    <button name="action_general" type="object" class="oe_highlight"
                            invisible="state != 'general'"
                            groups="atta_purchase_request.group_general"
                            string="Approve by General Manager" data-hotkey="w"/>
                </xpath>


                <xpath expr="//field[@name='order_line']/list"
                       position="inside">
                    <field name="request_line_id" invisible="1"/>
                </xpath>

                <xpath expr="//field[@name='currency_id']"
                       position="after">
                    <field name="request_uid"/>
                    <field name="department_id"/>
                </xpath>

                <xpath expr="//field[@name='order_line']/list/field[@name='product_id']"
                       position="attributes">
                    <attribute name="readonly">request_line_id or state in ['purchase', 'to approve', 'done', 'cancel']</attribute>
                </xpath>

                <xpath expr="//field[@name='order_line']/list/field[@name='name']"
                       position="attributes">
                    <attribute name="readonly">request_line_id</attribute>
                </xpath>

                <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_id']"
                       position="attributes">
                    <attribute name="readonly">request_line_id or state in ['purchase', 'done', 'cancel']</attribute>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
