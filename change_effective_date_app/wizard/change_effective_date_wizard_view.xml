<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="change_effective_date_views_form" model="ir.ui.view">
        <field name="name">change.effective.date.wizard.form</field>
        <field name="model">change.effective.date.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="date_done" required="1"/>
                    </group>
                    <group>
                        <field name="all_picking"/>
                        <field name="picking_id" invisible="1"/>
                    </group>
                </group>
                <footer>
                    <button name="update_effective_date" string="Update" type="object"
                        class="btn-primary"/>
                        or
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>