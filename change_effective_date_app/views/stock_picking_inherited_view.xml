<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="stock_picking_form_inherit_change_date" model="ir.ui.view">
		<field name="name">stock.picking.form.inherit</field>
		<field name="model">stock.picking</field>
		<field name="inherit_id" ref="stock.view_picking_form"/>
		<field name="arch" type="xml">
			<xpath expr="//form/header/button[@name='action_confirm']" position="after">
				<button name="action_change_effective_date"
						string="Change Effective Date"
						type="object"  invisible="state not in ['done','validate']"
						groups="change_effective_date_app.group_change_effective_date"
						class="oe_highlight"/>
<!--				groups="base.group_user"-->
			</xpath>
		</field>
	</record>

	<record id="action_server_change_effective_date" model="ir.actions.server">
            <field name="name">change date</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
			<field name="binding_model_id" ref="stock.model_stock_picking"/>
            <field name="state">code</field>
			<field name="code">
				action = {
    'type': 'ir.actions.act_window',
    'res_model': 'change.effective.date.wizard',
    'target': 'new',
    'views': [(env.ref('change_effective_date_app.change_effective_date_views_form').id, 'form')],
	'context':{'from_server_action': True, 'default_change_dates_ids':records.ids},
}
			</field>
        </record>
</odoo>
