<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_move_form_fleet_asset" model="ir.ui.view">
        <field name="name">account.move.form.fleet.asset</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='price_subtotal']"
                   position="before">
                <field name="linked_to"
                       string="Fleet / Asset"
                       optional="show"
                       widget="reference"/>
            </xpath>
        </field>
    </record>

</odoo>
