<odoo>

    <record model="ir.ui.view" id="view_account_payment_form_sgt">
        <field name="name">account.view_account_payment_form_sgt</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="model">account.payment</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="replace">
                <field name="state" widget="statusbar" statusbar_visible="draft,preposted,in_process,paid"/>
            </xpath>
            <xpath expr="//form/header/button[@name='action_post']" position="after">
                <button name="action_prepost" string="Pre-post" type="object" class="oe_highlight"
                        invisible="state != 'draft'" data-hotkey="v"/>
            </xpath>
            <xpath expr="//form/header/button[@name='action_post']" position="attributes">
                <attribute name="string">Posted</attribute>
                <attribute name="invisible">state != 'preposted'</attribute>
            </xpath>
        </field>
    </record>


    <record model="ir.ui.view" id="account_view_move_form_sgt">
        <field name="name">account.view_move_form_sgt</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="replace">
                <field name="state" widget="statusbar" statusbar_visible="draft,preposted,posted"/>
            </xpath>
            <xpath expr="//form/header/button[@name='action_post'][1]" position="after">
                <button name="action_prepost" string="Pre-post" type="object" class="oe_highlight"
                        invisible="state != 'draft'" data-hotkey="v"/>
            </xpath>
            <xpath expr="//form/header/button[@name='action_post']" position="attributes">
                <attribute name="string">Posted</attribute>
                <attribute name="invisible">state != 'preposted'</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_date']" position="attributes">
                <attribute name="readonly">state not in ('draft', 'preposted')</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="readonly">state not in ('draft', 'preposted')</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']" position="attributes">
                <attribute name="readonly">state not in ('draft', 'preposted')</attribute>
            </xpath>
        </field>
    </record>
</odoo>
