<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_hr_odoo_appraisal_rating_tree" model="ir.ui.view">
        <field name="name">hr.odoo.appraisal.rating.tree</field>
        <field name="model">hr.odoo.appraisal.rating</field>
        <field name="arch" type="xml">
            <list string="Appraisal Ratings">
                <field name="name"/>
                <field name="range_from"/>
                <field name="range_to"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hr_odoo_appraisal_rating_form" model="ir.ui.view">
        <field name="name">hr.odoo.appraisal.rating.form</field>
        <field name="model">hr.odoo.appraisal.rating</field>
        <field name="arch" type="xml">
            <form string="Appraisal Rating">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="range_from"/>
                        <field name="range_to"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hr_odoo_appraisal_rating" model="ir.actions.act_window">
        <field name="name">Appraisal Ratings</field>
        <field name="res_model">hr.odoo.appraisal.rating</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define rating ranges for appraisals.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_hr_odoo_appraisal_rating"
              name="Appraisal Ratings"
              parent="odoo_hr_evaluation_form.menu_human_resources_configuration_hr_evaluation"
              action="action_hr_odoo_appraisal_rating"
              sequence="10"/>
</odoo>
