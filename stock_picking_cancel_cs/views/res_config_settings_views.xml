<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_purchase_inherit" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.purchase</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="25"/>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Odoo 15/16 settings layout kept for migration reference.
            <xpath expr="//div[hasclass('settings')]/div[@data-string='Inventory']" position="inside">
                <h2>Cancel Delivery Order</h2>
                <div class="row mt16 o_settings_container">
                    <div class="col-xs-12 col-md-6 o_setting_box">
                        <div class="o_setting_left_pane">
                             <field name="cancel_done_picking"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="cancel_done_picking"/>
                        </div>
                    </div>
                </div>
            </xpath>
            -->
            <xpath expr="//app[@name='stock']/block[@name='operations_setting_container']" position="inside">
                <setting id="cancel_done_picking_setting"
                         string="Cancel Delivery Order"
                         company_dependent="1"
                         help="Allow authorized users to cancel completed delivery orders and reset cancelled transfers to draft.">
                    <field name="cancel_done_picking"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
