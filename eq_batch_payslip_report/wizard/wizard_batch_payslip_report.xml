<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<record model="ir.ui.view" id="hr_payroll_hr_salary_rule_category_form_cnss">
            <field name="name">account.view_move_form_kbsn</field>
            <field name="inherit_id" ref="hr_payroll.hr_salary_rule_category_form"/>
            <field name="model">hr.salary.rule.category</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='parent_id']" position="after">
					<field name="is_cnss"/>
					<field name="sequence_cnss"/>
					<field name="sequence_batch"/>
				</xpath>
			</field>
	</record>

	<record id="wizard_batch_payslip_report_view_form" model="ir.ui.view">
		<field name="name">wizard.batch.payslip.report.form</field>
		<field name="model">wizard.batch.payslip.report</field>
		<field name="arch" type="xml">
			<form>
				<group>
					<field name="state" invisible="1"/>
					<field name="name" invisible="1"/>
					<field name="batch_id" invisible="1"/>
				</group>

				<group invisible="state != 'choose' or context.get('type') == 'cnss'">
					<h4>* Click button to print Batch Payslip Report.</h4>
				</group>

				<group invisible="state != 'choose' or context.get('type') == 'batch'">
					<h4>* Click button to print CNSS Payslip Report.</h4>
				</group>

				<group>
					<field name="xls_file"
						readonly="1"
						filename="name"
						invisible="state != 'download'"/>
				</group>

				<group>
					<field name="hr_payroll_structure_id"
						invisible="xls_file"/>
				</group>

				<footer>

					<button name="print_report_xls"
							string="Print Excel"
							type="object"
							class="oe_highlight"
							invisible="state != 'choose' or context.get('type') == 'cnss'"/>

					<button name="print_report_xls"
							string="Print Excel"
							type="object"
							class="oe_highlight"
							invisible="state != 'choose' or context.get('type') == 'batch'"/>

					<button name="print_report_pdf"
							string="Print PDF"
							type="object"
							class="oe_highlight"
							invisible="state != 'choose' or context.get('type') == 'cnss'"/>

					<button name="action_go_back"
							string="Back"
							type="object"
							class="oe_highlight"
							invisible="state != 'download'"/>

					or
					<button string="Close" class="oe_link" special="cancel"/>
				</footer>
			</form>
		</field>
	</record>

	<record id="action_wizard_batch_payslip_report" model="ir.actions.act_window">
		<field name="name">Batch Payslip Report1</field>
		<field name="res_model">wizard.batch.payslip.report</field>
		<field name="view_mode">form</field>
		<field name="context">{'type': 'batch'}</field>
		<field name="target">new</field>
		<field name="binding_model_id" ref="hr_payroll.model_hr_payslip_run" />
		<field name="binding_view_types">form</field>
	</record>

	<record id="action_wizard_batch_payslip_report_new" model="ir.actions.act_window">
		<field name="name">Batch Payslip Report CNSS</field>
		<field name="res_model">wizard.batch.payslip.report</field>
		<field name="view_mode">form</field>
		<field name="context">{'type': 'cnss'}</field>
		<field name="target">new</field>
		<field name="binding_model_id" ref="hr_payroll.model_hr_payslip_run" />
		<field name="binding_view_types">form</field>
	</record>

</odoo>