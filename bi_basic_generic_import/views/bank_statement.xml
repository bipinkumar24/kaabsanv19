<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>


     <record id="bank_statement_import_line_wizard" model="ir.ui.view">
        <field name="name">bank.statement.import.line.wizard</field>
        <field name="model">account.bank.statement.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Bank Statement Lines">
                <group>
                    <field name="file" filename="file_name"/>
                    <field name="file_opt" widget="radio"/>
                </group>
                <footer>
                    <button name="import_file" string="Import" type="object"/>
                    or
                    <button string="Cancel" class="oe_link" special="cancel"/>
                    <div style="float: right;">
                        <strong>Download Sample:</strong>
                        <a role="button" href="/bi_basic_generic_import/static/Sample XLS-CSV File/Sample CSV File/import_bank_lines.csv" class="btn-primary" style="margin: 0 10px; font-size: 12px; line-height: 1.5; border-radius: 3px; padding: 8px 10px; color: #ffffff;">
                        <i class="fa fa-download"/>
                        CSV file
                        </a>
                        <a role="button" href="/bi_basic_generic_import/static/Sample XLS-CSV File/Sample XLS File/import_bank_lines.xls" class="btn-primary" style="font-size: 12px; line-height: 1.5; border-radius: 3px; padding: 8px 10px; color: #ffffff;">
                        <i class="fa fa-download"/>
                        Excel file
                        </a>
                    </div>
                </footer>
            </form>
        </field>
    </record>

        <record id="action_bank_statement_import_line_wizard" model="ir.actions.act_window">
            <field name="name">action bank statement import line wizard</field>
            <field name="res_model">account.bank.statement.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

   	 <record id="view_bank_statement_form_inherit_import_lines" model="ir.ui.view">
            <field name="name">account.bank.statement.form.import.lines</field>
            <field name="model">account.bank.statement</field>
            <field name="priority">5</field>
            <field name="inherit_id" eval="False"/>
            <field name="arch" type="xml">
                <form string="Bank Statement">
                    <header>
                        <button name="%(action_bank_statement_import_line_wizard)d" string="Add Lines" type="action" class="btn-primary"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="reference"/>
                                <field name="date"/>
                                <field name="journal_id" readonly="1"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                            <group>
                                <field name="currency_id" invisible="1"/>
                                <field name="balance_start"/>
                                <field name="balance_end"/>
                                <field name="balance_end_real"/>
                                <field name="is_complete" invisible="1"/>
                                <field name="is_valid" invisible="1"/>
                            </group>
                        </group>
                        <field name="problem_description" readonly="1" invisible="not problem_description"/>
                        <field name="line_ids" readonly="1">
                            <list>
                                <field name="date"/>
                                <field name="payment_ref"/>
                                <field name="ref"/>
                                <field name="partner_id"/>
                                <field name="amount"/>
                                <field name="currency_id" column_invisible="1"/>
                            </list>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>
     

  </data>
</odoo>
 
