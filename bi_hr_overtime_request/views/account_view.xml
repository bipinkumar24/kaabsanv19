<odoo>
    <record model="ir.ui.view" id="account_account_view_move_form_overtime">
        <field name="name">account.account.view.move.form.overtime</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_bank_id']" position="after">
                <field name="is_multiple_overtime_request" invisible="1"/>
                <field name="is_single_overtime_request" invisible="1"/>
                <field name="multiple_overtime_request_id" string="Overtime Document" invisible="is_multiple_overtime_request == False"/>
                <field name="overtime_request_id" string="Overtime Document" invisible="is_single_overtime_request == False"/>
            </xpath>
        </field>
    </record>

    <record model="ir.ui.view" id="account_view_move_form_kbsn_overtime">
        <field name="name">account.view_move_form_kbsn</field>
        <field name="inherit_id" ref="expense_requests.account_view_move_form_kbsn"/>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='is_expense']" position="before">
                <field name="is_overtime" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='require_custom_gm']" position="replace">
                <field name="require_custom_gm"
                       invisible="hide_hide_gm == True or is_expense == False or move_type == 'out_invoice' or is_overtime == True"/>
            </xpath>
        </field>
    </record>

    <record id="action_expense_requests_overtime" model="ir.actions.act_window">
        <field name="name">Overtime Expense</field>
        <field name="res_model">account.move</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_expense', '=', True),('move_type', '=', 'in_invoice'),('is_overtime', '=', True)]
        </field>
        <field name="context">{'default_move_type': 'in_invoice', 'default_is_expense': True,'hide_expense':1 }</field>
    </record>

    <menuitem id="menu_request_expenses_overtime" parent="expense_requests.expense_reques"
              name="Overtime Expense" action="action_expense_requests_overtime"
              groups="expense_requests.can_request_expenses,expense_requests.all_expensess_manager" sequence="2"/>

    <record model="ir.ui.view" id="hr_department_overtime">
        <field name="name">hr.view_department_form</field>
        <field name="inherit_id" ref="hr.view_department_form"/>
        <field name="model">hr.department</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="product_id" invisible="0"/>
            </xpath>
        </field>
    </record>
</odoo>
