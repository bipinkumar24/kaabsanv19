<?xml version="1.0"  encoding="utf-8"?>
<odoo>

    <record id="sequence_overtime_request" model="ir.sequence">
        <field name="name">Overtime Request Sequence</field>
        <field name="code">overtime.request</field>
        <field name="prefix">OTR/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="view_overtime_req_tree" model="ir.ui.view">
        <field name="name">overtime.request.tree</field>
        <field name="model">overtime.request</field>
        <field name="priority">2</field>
        <field name="arch" type="xml">
            <tree string="Overtime Request">
                <field name="name" readonly="1"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name='include_in_payroll'/>
                <field name="num_of_hours"/>
                <field name="payment_state"/>
            </tree>
        </field>
    </record>


    <record id="view_overtime_req_form" model="ir.ui.view">
        <field name="name">overtime.request.form</field>
        <field name="model">overtime.request</field>
        <field name="priority">2</field>
        <field name="arch" type="xml">
            <form string="Overtime Request">
                <header>
                    <button name="confirm_action" string="Confirm"
                            type="object" invisible="state != 'new'"/>

                    <button name="first_approve_action" string="Approve"
                            type="object" invisible="state != 'first_approve'"
                            groups="bi_hr_overtime_request.hr_manager_overtime_id"/>

                    <button name="dept_approve_action" string="Department Approve"
                            type="object" invisible="state != 'dept_approve'"
                            groups="bi_hr_overtime_request.dept_manager_overtime_id"/>

                    <button name="refuse_action" string="Refuse"
                            type="object"
                            groups="bi_hr_overtime_request.hr_manager_overtime_id,bi_hr_overtime_request.dept_manager_overtime_id"
                            invisible="state not in ('first_approve', 'dept_approve')"/>

                    <field name="state" widget="statusbar" statusbar_visible="new,first_approve,dept_approve,done"/>

                </header>
                <sheet>
                    <h2>
                        <field name="name" readonly="1"/>
                    </h2>
                    <br/>
                    <h2>
                        <field name="employee_id" readonly="state != 'new'"/>
                    </h2>
                    <group>
                        <group>
                            <field name="department_id" readonly="state != 'new'"/>
                            <field name="department_manager_id" readonly="state != 'new'"/>

                            <field name="approve_date"/>
                            <field name="approve_by_id"/>
                            <field name="num_of_hours"/>
                        </group>
                        <group>
                            <field name="include_in_payroll" readonly="state != 'new'" invisible="1"
                                   default="False"/>
                            <field name="dept_approve_date"/>
                            <field name="dept_manager_id"/>
                            <field name="bill_id" readonly="1"/>
                            <field name="payment_state"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">

                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>


    <record id="overtime_req_action" model="ir.actions.act_window">
        <field name="name">Overtime Request</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">overtime.request</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create"></p>
            <p></p>
        </field>
    </record>

    <menuitem id="sub_menu_employee_overtime" parent="bi_employee_advance_salary.admin_tab_id" name="Overtime"
              sequence="20"/>
    <menuitem action="overtime_req_action" id="menu_overtime" parent="sub_menu_employee_overtime"
              name="Overtime Request" sequence="29"/>

    <record id="overtime_req_action_hr" model="ir.actions.act_window">
        <field name="name">Overtime Request To Approve</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">overtime.request</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="domain">[('state','=','first_approve')]</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create"></p>
            <p></p>
        </field>
    </record>

    <menuitem action="overtime_req_action_hr" id="menu_overtime_hr" parent="sub_menu_employee_overtime"
              name="Overtime Request To Approve" sequence="29"
              groups="bi_hr_overtime_request.hr_manager_overtime_id"/>


    <record id="overtime_req_action_dept" model="ir.actions.act_window">
        <field name="name">Overtime Request To Approve By Department</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">overtime.request</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="domain">[('state','=','dept_approve')]</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create"></p>
            <p></p>
        </field>
    </record>


    <menuitem action="overtime_req_action_dept" id="menu_overtime_dept" parent="sub_menu_employee_overtime"
              name="Overtime Request To Approve By Department" sequence="30"
              groups="bi_hr_overtime_request.dept_manager_overtime_id"/>

</odoo>
