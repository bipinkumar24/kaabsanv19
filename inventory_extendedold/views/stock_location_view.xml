<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock_location_view_show_fual" model="ir.ui.view">
        <field name="name">stock.location.inherit.form</field>
        <field name="model">stock.location</field>
        <field name="inherit_id" ref="stock.view_location_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='replenish_location']" position="after">
                <field name="is_fual_expense"/>
            </xpath>
        </field>
    </record>
    <record id="fleet_vehicle_view_form_view" model="ir.ui.view">
        <field name="name">fleet.vehicle.inherit.form</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_accept_driver_change']" position="replace">
                <button name="action_update_odometers" string="Update Odometers" type="object" class="oe_highlight"/>
            </xpath>
        </field>
    </record>
</odoo>
