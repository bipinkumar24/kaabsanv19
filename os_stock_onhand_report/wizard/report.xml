<odoo>

    <template id="report_stock_onhand_information">
        <t t-call="web.html_container">
            <t t-set="docs" t-value="docs.with_context()"/>
            <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <div align="center">
                                <br/>
                                    <h2>Stock Onhand Report</h2>
                                </div>
                            <div>
                                <h4> Date:- <span t-field="doc.date_from" t-options='{"widget": "date","format": "dd-MM-yyyy"}'/></h4>
                            </div>
                            <t t-if="doc.display_current_stock">
                                <t t-foreach="docs.location_ids" t-as="loc">
                                    <div style="height:30%">
                                        <table border="1" class="table table-condensed" style="border-style:solid">
                                            <tr style="height:30%">
                                                <td style="border: 1px solid black;color:black;background-color:#f7e8f3;" align="center" class="thead-light">Location</td>
                                                <td style="border: 1px solid black" align="center">
                                                    <span t-field="loc.complete_name"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>

                                    <t t-set="net" t-value="0.0"/>
                                    <t t-if="doc.display_current_stock">
                                        <table border="1" class="table table-condensed"
                                               style="border-style:solid; text-align:center;">
                                            <tr style="background-color:#a77a9b;">
                                                <th style="border: 1px solid black;color:white;" class="thead-light">Internal Ref</th>
                                                <th style="border: 1px solid black;color:white;" class="thead-light">Product</th>
                                                <th style="border: 1px solid black;color:white;" class="thead-light">Qty</th>
                                                <th style="border: 1px solid black;color:white;" class="thead-light">Cost</th>
                                                <th style="border: 1px solid black;color:white;" class="thead-light">Total</th>
                                            </tr>
                                            <tr style="height:30%; text-align:center;">
                                                <tr t-foreach="docs.get_onhand_products(loc)" t-as="track">
                                                    <td t-out="track['code'] or ''" style="border: 1px solid black" class="thead-light"/>
                                                    <td t-out="track['product'] or ''" style="border: 1px solid black" class="thead-light"/>
                                                    <td t-out="track['qty'] or '0.0'" style="border: 1px solid black" class="thead-light"/>
                                                    <td t-out="track['cost'] or '0.0'" style="border: 1px solid black" class="thead-light"/>
                                                    <td t-out="track['total'] or '0.0'" style="border: 1px solid black" class="thead-light"/>
                                                    <t t-set="net" t-value="net + track['qty'] "/>
                                                </tr>
                                            </tr>
                                        </table>
                                        <br/>
                                    </t>
                                </t>
                            </t>
                            <table border="1" class="table table-condensed" style="border-style:solid; text-align:center;">
                                <tr style="background-color:#a77a9b;">
                                    <th style="border: 1px solid black;color:white;" class="thead-light">Product</th>
                                    <t t-foreach="docs.location_ids" t-as="loc">
                                        <th style="border: 1px solid black;color:white;" class="thead-light"><t t-out="loc.complete_name"/></th>
                                    </t>
                                    <th style="border: 1px solid black;color:white;" class="thead-light">Total Qty</th>
                                    <th style="border: 1px solid black;color:white;" class="thead-light">Unit Cost</th>
                                    <th style="border: 1px solid black;color:white;" class="thead-light">Total Value</th>
                                </tr>
                                <t t-set="Total_amount_value" t-value="0"/>
                                <t t-set="price" t-value="0"/>
                                <t t-foreach="docs.get_all_data()" t-as="line">
                                    <tr>
                                        <td t-out="line[0] or ''" style="border: 1px solid black" class="thead-light"/>
                                        <t t-foreach="line[1:-3]" t-as="qty">
                                            <td t-out="qty or ''" style="border: 1px solid black" class="thead-light"/>
                                        </t>
                                        <td t-out="'{0:,.4f}'.format(line[-3]) or ''" style="border: 1px solid black" class="thead-light"/>
<!--                                        <td t-out="line[-2] or ''" style="border: 1px solid black" class="thead-light" />-->
                                        <td t-out="'{0:,.4f}'.format(line[-2]) or ''" style="border: 1px solid black" class="thead-light" />

                                        <td t-out="'{0:,.4f}'.format(line[-1]) or ''" style="border: 1px solid black" class="thead-light"/>
                                        <t t-set="Total_amount_value" t-value="Total_amount_value + line[-1] or 0"/>
                                    </tr>
                                </t>
                            </table>
                            <div>
                                Total Amount Value:- <t t-out="Total_amount_value"/>
                            </div>
                        </div>
                    </t>
                </t>
        </t>
    </template>

     <record id="action_stock_onhand_report" model="ir.actions.report">
        <field name="name">Stock Onhand Report</field>
        <field name="model">stock.onhand.wiz</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">os_stock_onhand_report.report_stock_onhand_information</field>
        <field name="report_file">os_stock_onhand_report.report_stock_onhand_information</field>
        <field name="binding_model_id" ref="model_stock_onhand_wiz"/>
        <field name="binding_type">report</field>
    </record>

</odoo>