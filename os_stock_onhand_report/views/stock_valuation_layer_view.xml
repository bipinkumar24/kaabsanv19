<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- stock.valuation.layer was removed in Odoo 19; valuation is now on stock.move directly -->

    <record id="model_action_add_journal_entries" model="ir.actions.server">
        <field name="name">Add Accounting Entries</field>
        <field name="model_id" ref="stock.model_stock_move"/>
        <field name="binding_model_id" ref="stock.model_stock_move"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_add_journal_entries()</field>
    </record>

    <record id="model_stock_move_action_update_unit_price" model="ir.actions.server">
        <field name="name">Update Valuation Unit Price</field>
        <field name="model_id" ref="stock.model_stock_move"/>
        <field name="binding_model_id" ref="stock.model_stock_move"/>
        <field name="binding_view_types">form,list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_update_unit_price()</field>
    </record>

    <!-- Add quantity and cost columns to the Journal Items list view -->
    <record id="view_move_line_tree_grouped_inherit_budget_ent111" model="ir.ui.view">
        <field name="name">view.move.line.tree.grouped.inherit.budget.ent11</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='debit']" position="before">
                <field name="quantity" readonly="1" optional="hide"/>
                <field name="cost" readonly="1" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>
