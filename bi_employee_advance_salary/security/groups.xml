<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Top-level category shown as a section header on the user form -->
    <record id="module_category_advance_salary" model="ir.module.category">
        <field name="name">Advance Salary</field>
        <field name="sequence">50</field>
    </record>

    <!-- One privilege per group so each appears as its own independent toggle -->
    <record id="privilege_dept_manager_advance_salary" model="res.groups.privilege">
        <field name="name">Department Manager</field>
        <field name="sequence">10</field>
        <field name="category_id" ref="module_category_advance_salary"/>
    </record>

    <record id="privilege_hr_manager_advance_salary" model="res.groups.privilege">
        <field name="name">HR Manager</field>
        <field name="sequence">20</field>
        <field name="category_id" ref="module_category_advance_salary"/>
    </record>

    <record id="privilege_director_advance_salary" model="res.groups.privilege">
        <field name="name">Director</field>
        <field name="sequence">30</field>
        <field name="category_id" ref="module_category_advance_salary"/>
    </record>

    <record id="privilege_account_manager_advance_salary" model="res.groups.privilege">
        <field name="name">Account Manager</field>
        <field name="sequence">40</field>
        <field name="category_id" ref="module_category_advance_salary"/>
    </record>

    <!-- Groups linked to their own privilege (one-to-one = independent toggle) -->
    <record id="dept_manager_advance_salary_id" model="res.groups">
        <field name="name">Department Manager (Advance Salary)</field>
        <field name="privilege_id" ref="privilege_dept_manager_advance_salary"/>
    </record>

    <record id="hr_manager_advance_salary_id" model="res.groups">
        <field name="name">HR Manager (Advance Salary)</field>
        <field name="privilege_id" ref="privilege_hr_manager_advance_salary"/>
    </record>

    <record id="director_manager_advance_salary_id" model="res.groups">
        <field name="name">Director (Advance Salary)</field>
        <field name="privilege_id" ref="privilege_director_advance_salary"/>
    </record>

    <record id="account_manager_advance_salary_id" model="res.groups">
        <field name="name">Account Manager (Advance Salary)</field>
        <field name="privilege_id" ref="privilege_account_manager_advance_salary"/>
    </record>

</odoo>
