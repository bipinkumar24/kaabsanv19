<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="ir.actions.act_window" id="stock.action_stock_scrap">
        <field name="name">Scrap Orders</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">stock.scrap</field>
        <field name="domain">[('is_fual_expense', '=', False)]</field>
        <field name="view_mode">list,form,kanban,pivot,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Scrap products
            </p>
            <p>
                Scrapping a product will remove it from your stock. The product will
                end up in a scrap location that can be used for reporting purpose.
            </p>
        </field>
    </record>

    <record id='fleet_vehicle_odometer_view_tree_add_fuel' model='ir.ui.view'>
        <field name="name">fleet.vehicle.odometer.tree.car.inherit</field>
        <field name="model">fleet.vehicle.odometer</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_odometer_view_tree" />
        <field name="arch" type="xml">
            <field name="unit" position="after">
                <field name="stock_scrap_id" />
            </field>
        </field>
    </record>

    <record id="stock_scrap_form_view_scrap_fual" model="ir.ui.view">
        <field name="name">stock.scrap.inherit.form</field>
        <field name="model">stock.scrap</field>
        <field name="inherit_id" ref="stock.stock_scrap_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="effective_date" readonly="0"/>
                <field name="is_mutiline" readonly="state == 'done'"/>
            </xpath>
            <xpath expr="//field[@name='scrap_qty']" position="after">
                <field name="is_fual_expense" invisible="1"/>
                <field name="hide_validate" invisible="1"/>
            </xpath>
            <xpath expr="//button[@name='action_validate']" position="after">
                <button name="submit_procument_manager" type="object" class="btn-primary"
                        string="Submit Procurement Manager"
                        invisible="not is_fual_expense or state != 'draft'"/>
                <button name="submit_finance_approval" type="object" class="btn-primary"
                        string="Approve By Procurement Manager"
                        invisible="not is_fual_expense or state != 'procurement_manager'"
                        groups="inventory_extended.procurement_manager_group"/>
                <button name="action_reject" type="object" class="btn-primary" string="Reject By Procurement Manager"
                        invisible="not is_fual_expense or state != 'procurement_manager'"
                        groups="inventory_extended.procurement_manager_group"/>

                <button name="action_validate_data" string="Post Entry"
                        groups="inventory_extended.group_post_journal_entry"
                        class="btn-primary" type="object" invisible="state != 'done'"/>
                <button name="action_unpost_entery" string="unPost Entry"
                        groups="inventory_extended.group_post_journal_entry"
                        class="btn-primary" type="object" invisible="state != 'validate'"/>
            </xpath>
            <xpath expr="//button[@name='action_validate']" position="replace">
                <button name="action_validate" string="Stock Out" type="object" class="oe_highlight"
                        context="{'not_unlink_on_discard': True}"
                        invisible="hide_validate or state not in ['draft']"
                        data-hotkey="v"/>
                <button name="action_validate" string="Approve By Store Keeper" type="object" class="oe_highlight"
                        context="{'not_unlink_on_discard': True}"
                        invisible="state not in ['finance']" data-hotkey="v"
                        groups="inventory_extended.finance_manager_group"/>
                <button name="action_reject" type="object" class="btn-primary" string="Reject By Store Keeper"
                        invisible="not is_fual_expense or state != 'finance'"
                        groups="inventory_extended.finance_manager_group"/>
            </xpath>
            <xpath expr="//field[@name='state']" position="replace">
                <field name="state" widget="statusbar"
                       statusbar_visible="draft,procurement_manager,finance,done,validate"/>
            </xpath>
            <xpath expr="//div[hasclass('o_row')]" position="after">
                <field name="employee_id" invisible="not is_fual_expense"/>
                <field name="analytic_id" invisible="not is_fual_expense"/>
                <field name="request_uid" invisible="not is_fual_expense"/>
                <field name="department_id"
                       invisible="not is_fual_expense" required="is_fual_expense"/>
                <field name="type_data"
                       invisible="not is_fual_expense" required="is_fual_expense"/>
                <field name="fleet_id" invisible="not is_fual_expense" required="is_fual_expense"/>
                <field name="curreent_odoo_meter" invisible="not is_fual_expense"/>
                <field name="odometer" invisible="not is_fual_expense"/>
                <field name="consumption" invisible="not is_fual_expense"/>
                <field name="average_fuel" invisible="not is_fual_expense"/>
                <field name="equipment_id" invisible="not is_fual_expense"/>
            </xpath>
            <xpath expr="//button[@name='action_get_stock_move_lines']" position="replace">
                <button class="oe_stat_button" name="action_get_stock_move_lines"
                        string="Stock Moves" type="object"
                        invisible="not move_ids and not stock_move_ids" icon="fa-exchange"/>
            </xpath>

            <xpath expr="//sheet" position="inside">
                <field name="stock_move_ids" invisible="1"/>
                <notebook>
                    <page string="Muti-Location" invisible="not is_mutiline">
                        <field name="scrap_line_ids" readonly="state == 'done'">
                            <list editable="bottom">
                                <field name="company_id" invisible="1"/>
                                <field name="qty"/>
                                <!-- <field name="location_id"/> -->
                                <field name="scrap_location_id"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </xpath>

            <xpath expr="//field[@name='scrap_location_id']" position="attributes">
                <attribute name="invisible">is_mutiline</attribute>
                <attribute name="required">not is_mutiline</attribute>
                <attribute name="readonly">state == 'done'</attribute>
            </xpath>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_stock_scrap_fual_expense">
        <field name="name">Fuel Expense</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">stock.scrap</field>
        <field name="view_mode">list,form,kanban,pivot,graph</field>
        <field name="context">{'default_is_fual_expense': True}</field>
        <field name="domain">[('is_fual_expense', '=', True)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Scrap products
            </p>
            <p>
                Scrapping a product will remove it from your stock. The product will
                end up in a scrap location that can be used for reporting purpose.
            </p>
        </field>
    </record>

    <menuitem
            id="action_stock_scrap_fual_expense_data"
            name="Fuel Expense"
            parent="stock.menu_stock_warehouse_mgmt"
            action="action_stock_scrap_fual_expense"
            sequence="100"/>

</odoo>
