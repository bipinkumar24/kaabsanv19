<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="stock_scrap_form_view_scrap_fual" model="ir.ui.view">
        <field name="name">stock.scrap.inherit.form</field>
        <field name="model">stock.scrap</field>
        <field name="inherit_id" ref="stock.stock_scrap_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="effective_date"/>
            </xpath>
            <xpath expr="//field[@name='scrap_qty']" position="after">
                <field name="is_fual_expense" invisible="1"/>
                <field name="hide_validate" invisible="1"/>
            </xpath>
            <xpath expr="//button[@name='action_validate']" position="after">
                <button name="submit_procument_manager" type="object" class="btn-primary" string="Submit Produment Manager" invisible="(not is_fual_expense) or (state != 'draft')"/> 
                <button name="submit_finance_approval" type="object" class="btn-primary" string="Approve By Procurement Manager" invisible="not is_fual_expense or state != 'procurement_manager'" groups="inventory_extended.procurement_manager_group"/> 
                <button name="action_reject" type="object" class="btn-primary" string="Reject By Procurement Manager" invisible="not is_fual_expense or state != 'procurement_manager'" groups="inventory_extended.procurement_manager_group"/> 
            </xpath>
            <xpath expr="//button[@name='action_validate']" position="replace">
                <button name="action_validate" string="Stock Out" type="object" class="oe_highlight" context="{'not_unlink_on_discard': True}"  invisible="hide_validate or state != 'draft'" data-hotkey="v"/>
                <button name="action_validate" string="Approve By Finance Manager" type="object" class="oe_highlight" context="{'not_unlink_on_discard': True}"  invisible="state != 'finance'" data-hotkey="v"  groups="inventory_extended.finance_manager_group"/>
                <button name="action_reject" type="object" class="btn-primary" string="Reject By Finance Manager" invisible="not is_fual_expense or state != 'finance'"  groups="inventory_extended.finance_manager_group"/> 
            </xpath>
            <xpath expr="//field[@name='state']" position="replace">
                <field name="state" widget="statusbar" statusbar_visible="draft,procurement_manager,finance,done" />
            </xpath>
            <xpath expr="//div[hasclass('o_row')]" position="after">
                <field name="employee_id" invisible="not is_fual_expense"/>
                <field name="analytic_id" invisible="not is_fual_expense"/>
                <field name="request_uid" invisible="not is_fual_expense"/>
                <field name="department_id" invisible="not is_fual_expense"/>
                <field name="type_data" invisible="not is_fual_expense"/>
                <field name="fleet_id" invisible="not is_fual_expense"/>
                <field name="odometer" invisible="not is_fual_expense"/>
                <field name="equipment_id" invisible="not is_fual_expense"/>
            </xpath>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_stock_scrap_fual_expense">
        <field name="name">Fuel Expense</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">stock.scrap</field>
        <field name="view_mode">list,form,kanban,pivot,graph</field>
        <field name="context">{'default_is_fual_expense': True}</field>
        <field name="domain">[('is_fual_expense', '=', True)]</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Scrap products
          </p><p>
            Scrapping a product will remove it from your stock. The product will
            end up in a scrap location that can be used for reporting purpose.
          </p>
        </field>
    </record>

    <menuitem
        id="action_stock_scrap_fual_expense_data"
        name="Fuel Expense"
        parent="stock.menu_stock_warehouse_mgmt"
        action="action_stock_scrap_fual_expense"
        sequence="100"/>

</odoo>
