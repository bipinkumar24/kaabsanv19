<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- views/leave_report_wizard_view.xml -->
    <record id="view_leave_report_wizard_form" model="ir.ui.view">
        <field name="name">leave.report.wizard.form</field>
        <field name="model">leave.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Leave Report">
                <group>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="employee_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="print_report" type="object" string="Print Report" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_leave_report_wizard" model="ir.actions.act_window">
        <field name="name">Leave Report</field>
        <field name="res_model">leave.report.wizard</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_leave_report_wizard_form"/>
        <field name="context">{}</field>
        <field name="target">new</field>
    </record>

    <menuitem id="sub_menu_employee_leave_report"
        name="Leave Report"
        action="action_leave_report_wizard"
        parent="hr_holidays.menu_hr_holidays_report"/>

</odoo>
