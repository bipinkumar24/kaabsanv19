<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="leave_report_template">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Leave Report</h2>
                        <p>From: <t t-esc="data['form']['date_start']"/> To: <t t-esc="data['form']['date_end']"/></p>
                        <t t-foreach="docs.items()" t-as="employee_leaves">
                            <div class="mt-3">
                                <h4><t t-esc="employee_leaves[0].name"/></h4>
                                <table class="table table-sm table-bordered">
                                    <thead>
                                        <tr>
                                            <th>Leave Type</th>
                                            <th>From</th>
                                            <th>To</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="employee_leaves[1]" t-as="leave">
                                            <tr>
                                                <td><t t-esc="leave.holiday_status_id.name"/></td>
                                                <td><t t-esc="leave.date_from"/></td>
                                                <td><t t-esc="leave.date_to"/></td>
                                                <td><t t-esc="leave.state"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>
