<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_hr_employee_temp">
            <t t-call="web.html_container">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <h2 style="margin-left:220px;">Employee Leave Report</h2>

                            <table class="table table-condensed">
                                <thead>
                                    <tr>
                                        <th>Employee</th>
                                        <th>Leave Type</th>
                                        <th>Description</th>
                                        <th>From</th>
                                        <th>To</th>
                                        <th>Remaining Days</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                               <t t-foreach="docs" t-as="o">
                                  <t t-if="o">
                                      <tr>
                                          <td><t t-esc="o.employee_id.name"/></td>
                                          <td><t t-esc="o.holiday_status_id.name"/></td>
                                          <td><t t-esc="o.name"/></td>
                                          <td><t t-esc="o.date_from"/></td>
                                          <td><t t-esc="o.date_to"/></td>

                                          <td><t t-esc="o.remaining_leave"/></td>
                                          <td><t t-esc="holiday_type"/></td>
                                      </tr>
                                  </t>
                              </t>

                                </tbody>
                            </table>
                    
                        </div>
                    </t>
            </t>
        </template>
    </data>
</odoo>
