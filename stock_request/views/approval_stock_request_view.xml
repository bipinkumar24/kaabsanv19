<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>

        <record model="ir.ui.view" id="approval_stock_request_tree_view">
            <field name="name">approval.stock.request.tree.pr</field>
            <field name="model">approval.stock.request</field>
            <field name="arch" type="xml">
                <list string="Approval Level Form" editable="bottom">
                    <field name="name" />
                    <field name="level" />
                    <field name="is_last_approval" />
                    <field name="is_reject" />
                    <field name="approval_user_ids" widget="many2many_tags" required="not is_reject"/>
                    <field name="group_ids" widget="many2many_tags"/>
                    <field name="fields_ids" widget="many2many_tags" domain="[('model', '=', 'crm.lead.process2')]"/>
                    <field name="display_message"/>
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="approval_stock_request_form">
            <field name="name">approval.stock.request.form.pr</field>
            <field name="model">approval.stock.request</field>
            <field name="arch" type="xml">
                <form string="Approval Level Form">
                    <sheet>
                        <group>
                            <field name="name" required="1" />
                            <field name="level" required="1" />
                            <field name="is_last_approval" />
                            <field name="is_reject" />
                            <field name="approval_user_ids" widget="many2many_tags" required="not is_reject" />
                            <field name="group_ids" widget="many2many_tags"/>
                            <field name="display_message"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_approval_level_stock" model="ir.actions.act_window">
            <field name="name">Approval Level of Stock Request</field>
            <field name="res_model">approval.stock.request</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_approval_level_pr"
                  parent="stock_request.menu_stock_request_config_data"
                  name="Stock Request Approval Level"
                  action="action_approval_level_stock"
                  groups="base.group_system"
                  sequence="4" />
    </data>
</odoo>
