<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.stock_request</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Stock Request" string="Stock Request" name="stock_request" groups="stock_request.group_stock_request_manager">
                    <block title="Orders &amp; Configuration" name="stock_request_order_settings">
                        <setting id="stock_request_order_setting" string="Enable Orders" help="Activates Stock Request Orders">
                                <field name="group_stock_request_order" />
                        </setting>
                        <setting id="stock_request_virtual_location_setting" string="Allow All Locations Types" help="By default only internal and transit locations are allowed in Stock Request and Orders.">
                                <field name="stock_request_allow_virtual_loc" />
                        </setting>
                        <setting id="stock_request_submit_setting" string="Enable Submitted State" help="Add State to Stock Request and Stock Request Orders if activated.">
                                <field name="module_stock_request_submit" />
                        </setting>
                    </block>
                    <block title="Purchases" name="stock_request_purchase_settings">
                        <setting id="stock_request_purchase_setting" string="Enable Stock Requests for Purchases" help="Use Purchases with Stock Requests">
                                <field name="module_stock_request_purchase" />
                        </setting>
                    </block>
                    <block title="Manufacturing" name="stock_request_mrp_settings">
                        <setting id="stock_request_mrp_setting" string="Enable Stock Requests for Manufacturing" help="Use Manufacturing Orders with Stock Requests">
                                <field name="module_stock_request_mrp" />
                        </setting>
                    </block>
                    <block title="Kanban" name="stock_request_kanban_settings">
                        <setting id="stock_request_kanban_setting" string="Enable Stock Requests Kanban cards" help="Use Kanban cards for consumable products">
                                <field name="module_stock_request_kanban" />
                        </setting>
                    </block>
                    <block title="Analytic" name="stock_request_analytic_settings">
                        <setting id="stock_request_analytic_setting" string="Enable Analytic Accounting in Stock Requests" help="Analytic accounting in Stock Requests">
                                <field name="module_stock_request_analytic" />
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
    <record id="action_stock_request_config" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'stock_request'}</field>
    </record>

