<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="quotations_layout">
        <t t-if="not o" t-set="o" t-value="doc" />
        <t t-if="not company">
            <t t-if="company_id">
                <t t-set="company" t-value="company_id" />
            </t>
            <t t-elif="o and 'company_id' in o">
                <t t-set="company" t-value="o.company_id.sudo()" />
            </t>
            <t t-else="else">
                <t t-set="company" t-value="res_company" />
            </t>
        </t>
        <div t-attf-class="header o_company_#{company.id}_layout">
            <div class="row mt8">
                <div class="col-12">
                    <img src="/sale_invoice_report/static/img/header.jpg" alt="Logo" class="img-fluid margin-auto" />
                </div>
            </div>
        </div>
        <div class="article" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
            <t t-out="0" />
        </div>
        <div t-attf-class="footer o_company_#{company.id}_layout">
            <div class="row mt8">
                <div class="col-12 text-center">
                    <img src="/sale_invoice_report/static/img/footer.jpg" alt="Logo" class="img-fluid margin-auto" />
                </div>
            </div>
        </div>
    </template>
    <template id="report_sale_quotations">
        <t t-call="sale_invoice_report.quotations_layout">
            <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)" />
            <t t-set="forced_vat" t-value="doc.fiscal_position_id.foreign_vat"/>
            <div class="page"  style="
                background-image: url('/sale_invoice_report/static/img/bgimage.jpg');
                background-size: cover;
                background-repeat: no-repeat;
                background-position: center;
                width: 100%;
                height: 100%;
                position: relative;
                page-break-after: always;
            ">
                <style>
                .text_style {
                    color: #34297F;
                    font-family: "Trebuchet MS", sans-serif;
                    font-style: normal;
                    font-weight: bold;
                    text-decoration: none;
                    font-size: 12pt;
                    margin: 0pt;
                }
                .line {
                    color: #704A66;
                    font-family: "Trebuchet MS", sans-serif;
                    font-style: normal;
                    font-weight: bold;
                    text-decoration: none;
                    font-size: 11pt;
                    background-color: #dfddda;
                </style>
                <div class="col-12">
                    <div class="text-center">
                        <h1 class="text-center" style="color:#AE040E; font-weight: bold; font-size: 26.5pt;">
                            <t t-if="not (env.context.get('proforma', False) or is_pro_forma)">
                            <span t-if="doc.state not in ['draft','sent']">Order # </span>
                            <span t-if="doc.state in ['draft','sent']">Quotation # </span>
                        </t>
                        <t t-if="env.context.get('proforma', False) or is_pro_forma">
                            <span>Pro-Forma Invoice # </span>
                        </t>
                        <span t-field="doc.name"/>
                        </h1>
                    </div>
                    <img src="/sale_invoice_report/static/img/qrcode.png" height="130" class="margin-auto"/>
                </div>
                <div style="border-top: 1px solid #dddbdb; margin: 10px 0;"></div>
               
                <t t-if="doc.partner_id">
                    <div class="row mt32 mb32" style="width:100%; overflow: hidden; margin-bottom: 10px;">
                        <div class="col-md-9 mw-100 mb-2" style="width:68%; float:left;">
                            <string class="text_style">Customer Name: </string>
                            <t t-if="doc.partner_id.name">
                                <t t-esc="doc.partner_id.name"/>
                            </t><br/>
                            <string class="text_style">Contact Person: </string>
                            <t t-if="doc.partner_id.name">
                                <t t-esc="doc.partner_id.name"/>
                            </t><br/>
                            <string class="text_style">Telephone: </string>
                            <t t-if="doc.partner_id.phone">
                                <t t-esc="doc.partner_id.phone"/>
                            </t><br/>
                                <string class="text_style">Email: </string>
                            <t t-if="doc.partner_id.email">
                                <t t-esc="doc.partner_id.email"/>
                            </t><br/>
                            <string class="text_style">Address: </string>
                             <t t-if="doc.partner_id.street">
                                <t t-esc="doc.partner_id.street"/><br/>
                                <t t-esc="doc.partner_id.city"/>
                                <t t-esc="doc.partner_id.state_id.name"/><br/>
                                <t t-esc="doc.partner_id.country_id.name"/>
                               
                            </t>
                        </div>
                        <div class="col-md-3 mw-100 mb-2" style="width:32%; float:right;">
                            <string class="text_style">Quote Date: </string>
                            <t t-if="doc.date_order">
                                <sapn t-field="doc.date_order"/>
                            </t><br/>
                            <string class="text_style">Quote Number: </string>
                            <t t-if="doc.name">
                               <t t-esc="doc.name"/>
                            </t><br/>
                            <string class="text_style">Quote Validity: </string>
                            <t t-if="doc.payment_term_id">
                                <t t-esc="doc.payment_term_id.name"/>
                            </t><br/>
                            <string class="text_style">Issued By: </string>
                            <t t-if="doc.partner_id.name">
                                <t t-esc="doc.user_id.name"/>
                            </t>
                        </div>
                    </div>
                    <t t-set="display_discount" t-value="any(l.discount for l in doc.order_line)"/>

            <table class="table table-sm o_main_table">
                <!-- In case we want to repeat the header, remove "display: table-row-group" -->
                <thead style="display: table-row-group">
                    <tr>
                        <th name="th_description" class="text-left text_style pt-2">Description</th>
                        <th name="th_quantity" class="text-right text_style pt-2">Quantity</th>
                        <th name="th_priceunit" class="text-right text_style pt-2">Unit Price</th>
                        <th name="th_discount" t-if="display_discount " class="text-right text_style pt-2" groups="product.group_discount_per_so_line">
                            <span>Disc.%</span>
                        </th>
                        <th name="th_taxes" class="text-right text_style pt-2">Taxes</th>
                        <th name="th_subtotal" class="text-right text_style pt-2">
                            <span groups="account.group_show_line_subtotals_tax_excluded">Amount</span>
                            <span groups="account.group_show_line_subtotals_tax_included">Total Price</span>
                        </th>
                    </tr>
                </thead>
                <tbody class="sale_tbody line">

                    <t t-set="current_subtotal" t-value="0"/>

                    <t t-foreach="doc.order_line" t-as="line">

                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                        <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                            <t t-if="not line.display_type">
                                <td name="td_name"><span t-field="line.name"/></td>
                                <td name="td_quantity" class="text-right">
                                    <span t-field="line.product_uom_qty"/>
                                    <span t-field="line.product_uom_id"/>
                                </td>
                                <td name="td_priceunit" class="text-right">
                                    <span t-field="line.price_unit"/>
                                </td>
                                <td t-if="display_discount" class="text-right" groups="product.group_discount_per_so_line">
                                    <span t-field="line.discount"/>
                                </td>
                                <td name="td_taxes" class="text-right">
                                    <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_ids))"/>
                                </td>
                                <td name="td_subtotal" class="text-right o_price_total">
                                    <span t-field="line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                    <span t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                </td>

                            </t>
                            <t t-if="line.display_type == 'line_section'">
                                <td name="td_section_line" colspan="99">
                                    <span t-field="line.name"/>
                                </td>
                                <t t-set="current_section" t-value="line"/>
                                <t t-set="current_subtotal" t-value="0"/>
                            </t>
                            <t t-if="line.display_type == 'line_note'">
                                <td name="td_note_line" colspan="99">
                                    <span t-field="line.name"/>
                                </td>
                            </t>
                        </tr>

                        <t t-if="current_section and (line_last or doc.order_line[line_index+1].display_type == 'line_section')">
                            <tr class="is-subtotal text-right">
                                <td name="td_section_subtotal" colspan="99">
                                    <strong class="mr16">Subtotal</strong>
                                    <span
                                        t-esc="current_subtotal"
                                        t-options='{"widget": "monetary", "display_currency": doc.pricelist_id.currency_id}'
                                    />
                                </td>
                            </tr>
                        </t>
                    </t>
                </tbody>
            </table>
            <div class="clearfix" name="so_total_summary">
                <div id="total" class="row" name="total">
                    <div t-attf-class="#{'col-6' if report_type != 'html' else 'col-sm-7 col-md-6'} ml-auto">
                        <table class="table table-sm">
                            <!-- Tax totals -->
                            <t t-set="tax_totals" t-value="doc.tax_totals"/>
                            <t t-set="currency" t-value="doc.currency_id"/>
                            <t t-call="account.document_tax_totals"/>
                        </table>
                    </div>
                </div>
            </div>

            <!-- <div>
                <string class="text_style">Additional Information: </string>
                <t t-if="doc.note">
                    <t t-esc="doc.note"/>
                </t>
            </div> -->
                </t>
            </div>
        </t>
    </template>
    <template id="reportsale_quotations">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="sale_invoice_report.report_sale_quotations"/>
            </t>
        </t>
    </template>
    <record id="sale_quotations_report" model="ir.actions.report">
        <field name="name">Quotations Report</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sale_invoice_report.reportsale_quotations</field>
        <field name="report_file">sale_invoice_report.reportsale_quotations</field>
        <field name="attachment_use" eval="False"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>
</odoo>