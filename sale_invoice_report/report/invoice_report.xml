<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="invocie_layout">

        <t t-if="not o" t-set="o" t-value="doc" />
        <t t-if="not company">
            <t t-if="company_id">
                <t t-set="company" t-value="company_id" />
            </t>
            <t t-elif="o and 'company_id' in o">
                <t t-set="company" t-value="o.company_id.sudo()" />
            </t>
            <t t-else="else">
                <t t-set="company" t-value="res_company" />
            </t>
        </t>
        <div t-attf-class="header o_company_#{company.id}_layout" >
             <div class="row col-12" >
                <div class="col-7"></div>
                <div class="col-5">
                    <img t-att-src="image_data_uri(company.logo)" height="220" class=" img-fluid margin-auto" style="margin-top:-10px;"/>
                </div>
            </div>
        </div>
        <div class="article" t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')">
            <t t-out="0" />
        </div>
        <div t-attf-class="footer o_company_#{company.id}_layout">
            <style>
            .tital {
                        color: black;
                        font-family: "Arial Black", sans-serif;
                        font-style: normal;
                        font-weight: bold;
                        text-decoration: none;
                        font-size: 15pt;
                        margin: 0pt;
                    }
            </style>
            <div style="border-top: 1px solid #dddbdb; margin: 10px 0;"></div>
            <div class="row col-12">
                    <div class="col-5 text-left">
                        <div class="mt-2">
                            <strong class="tital" style="padding-right: 64px">Zaad Acc   </strong> 504550<br/>
                        </div>
                        <div class="mt-2">
                            <strong class="tital" style="padding-right: 81px">eDahab   </strong>87111<br/>
                        </div>
                        <div class="mt-2">
                            <strong class="tital" style="padding-right: 22px">Dara Salaam   </strong>60895598<br/>
                        </div>
                    </div>
                    <div class="col-4 text-center">
                        <img src="/sale_invoice_report/static/img/invoice_stamp.jpg" height="130" class="margin-auto"/>
                    </div>
                    <div class="col-3"></div><br/>
            </div>
            <div style="border-top: 1px solid #dddbdb; margin: 10px 0;"></div>
            <h5 class="text-center">If you have any question please contact : 636100001 , 636100002</h5>

        </div>
    </template>
    <template id="report_invoice_document_new">
            <t t-call="sale_invoice_report.invocie_layout">
                <t t-set="o" t-value="o.with_context(lang=lang)"/>
                <t t-set="forced_vat" t-value="o.fiscal_position_id.foreign_vat"/>
                <t t-set="address">
                    <address t-field="o.partner_id" t-options="{&quot;widget&quot;: &quot;contact&quot;, &quot;fields&quot;: [&quot;address&quot;, &quot;name&quot;], &quot;no_marker&quot;: True}"/>
                    <div t-if="o.partner_id.vat" class="mt16">
                        <t t-if="o.company_id.account_fiscal_country_id.vat_label" t-esc="o.company_id.account_fiscal_country_id.vat_label" id="inv_tax_id_label"/>
                        <t t-else="">Tax ID</t>: <span t-field="o.partner_id.vat"/></div>
                </t>
                <style>
                    .s1 {
                        color: black;
                        font-family: "Verdana", sans-serif;
                        font-size: 48.5pt;
                    }
                    .tital {
                        color: black;
                        font-family: "Arial Black", sans-serif;
                        font-style: normal;
                        font-weight: bold;
                        text-decoration: none;
                        font-size: 13pt;
                        margin: 0pt;
                    }
                    .text {
                        color: #484646;;
                        font-family: "Arial";
                        font-size: 13pt;
                    }
                </style>
                <div class="page" style="                 background-image: url('/sale_invoice_report/static/img/bgimage.jpg');                 background-size: auto;                 background-repeat: no-repeat;             ">
                    <div class="row col-12">
                        <div class="col-7" style="font-family: 'DejaVu Sans', 'DejaVu Sans Light', sans-serif;">
                            <p class="s1"> INVOICE</p>
                        </div>
                        <div class="col-5">
                         <p class="text-center">
                            <t t-if="o.company_id.name"><t t-esc="o.company_id.name"/><br/></t>
                            <t t-if="o.company_id.street"><t t-esc="o.company_id.street"/><br/></t>
                            <t t-if="o.company_id.city"><t t-esc="o.company_id.city"/></t>
                            <t t-if="o.company_id.state_id"><span t-field="o.company_id.state_id"/></t>
                            <t t-if="o.company_id.zip"> <span t-field="o.company_id.zip"/><br/></t>
                            <t t-if="o.company_id.country_id"><span t-field="o.company_id.country_id"/><br/></t>
                            <t t-if="o.company_id.phone"> Tell: <span t-field="o.company_id.phone"/></t>
                            </p>
                        </div>
                    </div>
                    <div class="row col-12">
                        <div class="col-8">
                            <div class="row">
                                <div class="col-4">
                                    <span class="tital">Invoice No :</span><br/>
                                    <span class="tital">Order :</span><br/>
                                    <t t-if="o.project_details">
                                        <span class="tital">Project :</span><br/>
                                    </t>
                                    <span class="tital">Bill to :</span>
                                </div>
                    
                                <div class="col-8">
                                    <b>
                                        <span t-if="o.name != '/'" t-field="o.name"/>
                                    </b><br/>
                    
                                    <span t-field="o.invoice_origin"/><br/>
                    
                                    <t t-if="o.project_details">
                                        <span t-field="o.project_details"/><br/>
                                    </t>
                    
                                    <t t-if="o.partner_id">
                                        <div class="text">
                                            <span t-field="o.partner_id.name"/><br/>
                    
                                            <t t-if="o.partner_id.street">
                                                <span t-field="o.partner_id.street"/><br/>
                                            </t>
                    
                                            <t t-if="o.partner_id.city">
                                                <span t-field="o.partner_id.city"/>
                                            </t>
                    
                                            <span t-field="o.partner_id.state_id"/>
                                            <span t-field="o.partner_id.zip"/><br/>
                    
                                            <span t-field="o.partner_id.country_id"/><br/>
                    
                                            <t t-if="o.partner_id.phone">
                                                Tel: <span t-field="o.partner_id.phone"/>
                                            </t>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
            
                        <div class="col-4 text-start" t-if="o.invoice_date" name="invoice_date">
                            <br/>
                            <strong>Date :</strong>
                            <span t-field="o.invoice_date" t-options='{"widget": "date"}'/>
                        </div>
                    </div>
                    <table class="table o_main_table table-borderless mb-0">
                        <thead>
                            <tr>
                                <th class="text-center"><strong>Item</strong></th>
                                <th class="text-start"><strong>Description</strong></th>
                                <th class="text-end"><strong>Quantity</strong></th>
                                <th class="text-end"><strong>Unit Price</strong></th>
                                <th class="text-start"><strong>Taxes</strong></th>
                                <th class="text-end"><strong>Amount</strong></th>
                            </tr>
                        </thead>

                        <tbody>
                            <t t-set="sr" t-value="0"/>
                            <t t-foreach="o.invoice_line_ids" t-as="line">
                    
                                <t t-if="line.display_type == 'product'">
                                    <t t-set="sr" t-value="sr + 1"/>
                                    <tr>
                                        <td class="text-center"><t t-out="sr"/></td>
                                        <td><span t-field="line.name" t-options="{'widget': 'text'}"/></td>
                                        <td class="text-end">
                                            <span t-field="line.quantity"/>
                                            <span t-field="line.product_uom_id" groups="uom.group_uom"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-field="line.price_unit"/>
                                        </td>
                                        <td class="text-start">
                                            <t t-set="taxes" t-value="', '.join(tax.name for tax in line.tax_ids)"/>
                                            <span t-out="taxes"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-field="line.price_subtotal"/>
                                        </td>
                                    </tr>
                                </t>
                    
                                <t t-elif="line.display_type == 'line_section'">
                                    <tr><td colspan="6"><strong t-field="line.name"/></td></tr>
                                </t>
                    
                                <t t-elif="line.display_type == 'line_note'">
                                    <tr><td colspan="6"><em t-field="line.name"/></td></tr>
                                </t>
                    
                            </t>
                        </tbody>
                    </table>
                    <div class="overflow-hidden">
                        <div id="right-elements" t-attf-class="#{'col-5 mt-5' if report_type == 'pdf' else 'col-12 col-md-5'} ms-5 d-inline-block float-end">
                            <div id="total" class="clearfix row">
                                <div class="ms-auto">
                                    <table class="o_total_table table table-borderless avoid-page-break-inside">
                    
                                        <!-- Tax totals -->
                                        <t t-if="o.tax_totals" t-call="account.document_tax_totals">
                                            <t t-set="tax_totals" t-value="o.tax_totals"/>
                                            <t t-set="currency"   t-value="o.currency_id"/>
                                        </t>
                    
                                        <!-- Discount (your custom fields) -->
                                        <tr t-if="o.discount_amt">
                                            <td><strong>Discount</strong></td>
                                            <td class="text-end">
                                                <span t-field="o.discount_amt"
                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr t-if="o.discount_amt_line">
                                            <td><strong>Discount</strong></td>
                                            <td class="text-end">
                                                <span t-field="o.discount_amt_line"
                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                        </tr>
                    
                                        <!-- Payments -->
                                        <t t-if="print_with_payments">
                                            <t t-if="o.payment_state != 'invoicing_legacy'">
                                                <t t-set="payments_vals"
                                                   t-value="o.sudo().invoice_payments_widget and o.sudo().invoice_payments_widget['content'] or []"/>
                                                <t t-foreach="payments_vals" t-as="payment_vals">
                                                    <tr t-if="payment_vals['is_exchange'] == 0">
                                                        <td>
                                                            <i class="oe_form_field text-end oe_payment_label">
                                                                <t t-if="payment_vals['is_refund']">Reversed on </t>
                                                                <t t-else="">Paid on </t>
                                                                <t t-out="payment_vals['date']"
                                                                   t-options='{"widget": "date"}'/>
                                                            </i>
                                                        </td>
                                                        <td class="text-end">
                                                            <span t-out="payment_vals['amount']"
                                                                  t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                                        </td>
                                                    </tr>
                                                </t>
                                                <t t-if="len(payments_vals) > 0">
                                                    <tr class="fw-bold">
                                                        <td>Amount Due</td>
                                                        <td class="text-end">
                                                            <span t-field="o.amount_residual"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </t>
                                        </t>
                    
                                    </table>
                                </div>
                            </div>
                            <div class="mb-2">
                                <p class="text-end lh-sm" t-if="o.company_id.display_invoice_amount_total_words">
                                    Total amount in words: <br/>
                                    <small class="text-muted lh-sm">
                                        <span t-field="o.amount_total_words"/>
                                    </small>
                                </p>
                            </div>
                        </div>
                    </div>
                    <p t-if="o.invoice_payment_term_id" name="payment_term">
                        <span t-field="o.invoice_payment_term_id.note"/>
                    </p>
                    <p t-if="o.invoice_incoterm_id" name="incoterm">
                        <strong>Incoterm: </strong><span t-field="o.invoice_incoterm_id.code"/> - <span t-field="o.invoice_incoterm_id.name"/>
                    </p>
                    <div id="qrcode" t-if="o.display_qr_code and o.amount_residual &gt; 0">
                        <p t-if="qr_code_urls.get(o.id)">
                            <strong class="text-center">Scan me with your banking app.</strong><br/><br/>
                            <img class="border border-dark rounded" t-att-src="qr_code_urls[o.id]"/>
                        </p>
                    </div>
                </div>
            </t>
    </template>

    <template id="report_invoice_new">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="sale_invoice_report.report_invoice_document_new"/>
            </t>
        </t>
    </template>

    <record id="paperformat_invoice" model="report.paperformat">
        <field name="name">Invoice Report</field>
        <field name="format">custom</field>
        <field name="orientation">Portrait</field>
        <field name="page_height">297</field>
        <field name="page_width">210</field>
        <field name="margin_top">55</field>
        <field name="margin_bottom">45</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">50</field>
        <field name="dpi">90</field>
    </record>
    <record id="invoice_report_action" model="ir.actions.report">
        <field name="name">Invoice Report</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sale_invoice_report.report_invoice_new</field>
        <field name="report_file">sale_invoice_report.report_invoice_new</field>
        <field name="paperformat_id" ref="sale_invoice_report.paperformat_invoice"/>
        <field name="attachment_use" eval="False"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
    </record>

        <!--We need to create the following empty report template for the action report
            "action_account_original_vendor_bill" to work. The action is merging the
            original vendor bill(s) that were used to create the vendor bill(s) into one PDF. -->
        <template id="report_original_vendor_bill">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <div class="article"  t-att-data-oe-model="o and o._name" t-att-data-oe-id="o and o.id" t-att-data-oe-lang="o and o.env.context.get('lang')"></div>
                </t>
            </t>
    </template>
</odoo>
