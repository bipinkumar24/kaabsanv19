<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_project_details" model="ir.ui.view">
        <field name="name">sale.order.form.project.details</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
             <xpath expr="//field[@name='partner_shipping_id']" position='after'>
                <field name="project_details" required="1"/>
            </xpath>
        </field>
    </record>
    <record id="view_move_form_inherit_project_details" model="ir.ui.view">
        <field name="name">account.move.form.project.details</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <field name="invoice_vendor_bill_id" position="after">
                <field name="project_details" readonly="0" required="move_type == 'out_invoice'"/>
            </field>
        </field>
    </record>
</odoo>