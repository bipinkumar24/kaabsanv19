<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Button on scrap form view header -->
    <record id="stock_scrap_form_view_inherit_effective_date" model="ir.ui.view">
        <field name="name">stock.scrap.form.inherit.effective.date</field>
        <field name="model">stock.scrap</field>
        <field name="inherit_id" ref="stock.stock_scrap_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_validate']" position="after">
                <button name="action_change_effective_date"
                        string="Change Effective Date"
                        type="object"
                        invisible="state not in ('done', 'validate')"
                        class="btn-secondary"/>
            </xpath>
        </field>
    </record>

    <!-- Server action bound to scrap list and form (Action menu) -->
    <record id="action_server_change_scrap_effective_date" model="ir.actions.server">
        <field name="name">Change Effective Date</field>
        <field name="model_id" ref="stock.model_stock_scrap"/>
        <field name="binding_model_id" ref="stock.model_stock_scrap"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
if records:
    action = records[0].action_change_effective_date()
        </field>
    </record>
</odoo>
