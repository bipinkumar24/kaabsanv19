<?xml version="1.0"?>
<odoo>
    <data>
        
        <record id="view_order_invoice_discount_form" model="ir.ui.view">
             <field name="name">sale.order.invoice.discount.form.view</field>
             <field name="model">sale.order</field>
             <field name="inherit_id" ref="sale.view_order_form" />
             <field name="arch" type="xml">

                <field name="payment_term_id" position="after">
                    <field name="discount_type" widget="radio"/>
                </field>

                <xpath expr="//group[@name='sale_total']" position="after">
                    <group>
                        <label for="discount_method" invisible="discount_type == 'line'"/>
                        <div>
                            <field name="discount_method" class="oe_inline" invisible="discount_type == 'line'"/>
                        </div>
                         <label for="discount_amount" invisible="discount_type == 'line'"/>
                        <div>
                            <field name="discount_amount" class="oe_inline" invisible="discount_type == 'line'"/>
                            <label for="discount_amount" string="%" invisible="discount_method != 'per'" class="oe_inline"/>
                         </div>
                    </group>
                </xpath>

                <xpath expr="//group[hasclass('oe_subtotal_footer')]" position="replace">
                    <group class="oe_subtotal_footer oe_right" colspan="2" name="sale_total">
                        <field name="discount_amt" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="discount_type == 'line'" colspan="2"/>
                        <field name="discount_amt_line" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="discount_type == 'global'" colspan="2"/>
                        <field name="tax_totals" widget="account-tax-totals-field" nolabel="1" colspan="2" readonly="1"/>
                    </group>
                </xpath>

                <xpath expr="//field[@name='order_line']//list/field[@name='product_uom_qty']" position="before">
                    <field name="discount_type" invisible="1"/>
                    <field name="discount_method" column_invisible="parent.discount_type == 'global'" invisible="discount_type == 'global'"/>
                    <field name="discount_amount" column_invisible="parent.discount_type == 'global'" invisible="discount_type == 'global'"/>
                    <field name="discount_amt" invisible="1"/>
                </xpath>

                <xpath expr="//field[@name='order_line']/form/group/group/field[@name='price_unit']" position="before">
                    <field name="discount_type" invisible="1"/>
                    <field name="discount_amt" invisible="1"/>
                    <label for="discount_method" string="Discount Method" invisible="parent.discount_type == 'global'"/>
                    <div invisible="parent.discount_type == 'global'">
                        <field name="discount_method" invisible="parent.discount_type == 'global'"/>
                    </div>
                    <label for="discount_amount" string="Discount Amount"
                        invisible="parent.discount_type == 'global'"/>
                    <div invisible="parent.discount_type == 'global'">
                        <field name="discount_amount" invisible="parent.discount_type == 'global'"/>
                    </div>
                </xpath>

                <xpath expr="//field[@name='order_line']//list/field[@name='discount']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//field[@name='order_line']/form//label[@for='discount']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//field[@name='order_line']/form//div[@name='discount']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='order_line']/form//div[@name='discount']/field[@name='discount']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_account_invoice_discount_form" model="ir.ui.view">
            <field name="name">account.invoice.discount.form.view</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                
                <xpath expr="//div[@name='journal_div']" position="after">
                    <field name="discount_type" widget="radio" invisible="move_type in ('in_invoice', 'in_refund', 'in_receipt')"/>
                </xpath>

                <xpath expr="//field[@name='tax_totals']/ancestor::group[hasclass('oe_subtotal_footer')]" position="before">
                    <group style="width: 65%" invisible="move_type in ('in_invoice', 'in_refund', 'in_receipt')">
                        <label for="discount_method" invisible="discount_type == 'line'"/>
                        <div>
                            <field name="discount_method" class="oe_inline" invisible="discount_type == 'line'"/>
                        </div>
                        <label for="discount_amount" invisible="discount_type == 'line'"/>
                        <div>
                            <field name="discount_amount" class="oe_inline" invisible="discount_type == 'line'"/>
                            <label for="discount_amount" string="%"
                                invisible="discount_method != 'per'" class="oe_inline"/>
                                <button name="calc_discount"  string="(Apply)" type="object"
                                class="oe_edit_only oe_link"
                                invisible="state not in ('draft', 'sent') or discount_type == 'line'"/>
                        </div>
                    </group>
                </xpath>

                <xpath expr="//field[@name='tax_totals']/ancestor::group[hasclass('oe_subtotal_footer')]" position="replace">
                    <group class="oe_subtotal_footer oe_right" colspan="2" name="invoice_total"
                        invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt') or payment_state == 'invoicing_legacy'">
                        <field name="discount_amt" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="discount_type == 'line' or move_type in ('in_invoice', 'in_refund', 'in_receipt')" colspan="2"/>
                        <field name="discount_amt_line" widget="monetary" options="{'currency_field': 'currency_id'}" invisible="discount_type == 'global' or move_type in ('in_invoice', 'in_refund', 'in_receipt')"/> 
                        <field name="discount_amount_line"  invisible="1"/>                       
                        <field name="tax_totals" widget="account-tax-totals-field" nolabel="1" colspan="2"
                            readonly="state != 'draft' or (move_type not in ('in_invoice', 'in_refund', 'in_receipt') and not quick_edit_mode)"/>
                        <field name="invoice_payments_widget" colspan="2" nolabel="1" widget="payment" invisible="not invoice_payments_widget"/>
                        <field name="amount_residual" class="oe_subtotal_footer_separator"/>
                    </group>
                </xpath>
                                
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='discount']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='quantity']" position="before">
                    <field name="discount_type" invisible="1"/>
                    <field name="discount_amt" invisible="1"/>
                    <field name="discount_method" column_invisible="parent.discount_type == 'global'" invisible="discount_type == 'global'"/>
                    <field name="discount_amount" column_invisible="parent.discount_type == 'global'" invisible="discount_type == 'global'"/>
                </xpath>
     
                <xpath expr="//field[@name='line_ids']/list/field[@name='tax_tag_ids']" position="after">
                    <field name="discount_type" invisible="1"/>
                    <field name="discount_method" invisible="1"/>
                    <field name="discount_amount" invisible="1"/>
                    <field name="discount_amt" invisible="1"/>
                </xpath>
                
            </field>
        </record>


        <record id="res_config_settings_view_form_discount" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.discount</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="10"/>
            <field name="inherit_id" ref="sale.res_config_settings_view_form" />
            <field name="arch" type="xml">
                <xpath expr="//setting[@id='discount_sale_order_lines']" position="after">
                    <setting id="discount_tax_policy" string="Discount Tax Policy" help="Choose whether discount amounts reduce taxes or are applied after taxes.">
                        <field name="tax_discount_policy" widget="radio"/>
                    </setting>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
