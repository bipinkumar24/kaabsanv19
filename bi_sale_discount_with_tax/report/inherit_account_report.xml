<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_invoice_discount_inherit" inherit_id="account.report_invoice_document">
            <xpath expr="//t[@t-set='display_discount']" position="attributes">
                <attribute name="t-value">any(l.discount for l in o.invoice_line_ids) or o.discount_type == 'line'</attribute>
            </xpath>

            <xpath expr="//div[@name='reference']" position="after">
                <div t-if="o.move_type in ('out_invoice', 'out_refund', 'out_receipt') and o.discount_type" name="discount_type" class="col">
                    <strong>Discount Type</strong>
                    <div t-field="o.discount_type"/>
                </div>
            </xpath>

            <xpath expr="//th[@name='th_discount']" position="replace">
                <th name="th_discount" t-if="display_discount" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                    <span t-if="o.discount_type == 'line'">Discount</span>
                    <span t-else="">Disc.%</span>
                </th>
            </xpath>

            <xpath expr="//td[@name='td_discount']" position="replace">
                <td name="td_discount" t-if="display_discount" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                    <t t-if="o.discount_type == 'line'">
                        <t t-if="line.discount_amount">
                            <span t-field="line.discount_method"/>
                            <span t-field="line.discount_amount"/>
                            <span t-if="line.discount_method == 'per'">%</span>
                        </t>
                        <span t-else="">-</span>
                    </t>
                    <span t-else="" class="text-nowrap" t-field="line.discount">0</span>
                </td>
            </xpath>

            <xpath expr="//div[@id='total']" position="after">
                <div t-if="o.move_type in ('out_invoice', 'out_refund', 'out_receipt') and o.discount_type" class="row mt-2" name="discount_summary">
                    <div class="ms-auto">
                        <table class="table table-sm table-borderless">
                            <tr t-if="o.discount_type == 'global'">
                                <td>Discount Method</td>
                                <td class="text-end">
                                    <span t-field="o.discount_method"/>
                                </td>
                            </tr>
                            <tr t-if="o.discount_type == 'global'">
                                <td>Discount Amount</td>
                                <td class="text-end">
                                    <span t-field="o.discount_amount"/>
                                    <span t-if="o.discount_method == 'per'">%</span>
                                </td>
                            </tr>
                            <tr t-if="o.discount_type == 'global'">
                                <td>Discount</td>
                                <td class="text-end">
                                    <span t-field="o.discount_amt"/>
                                </td>
                            </tr>
                            <tr t-if="o.discount_type == 'line'">
                                <td>Line Discount</td>
                                <td class="text-end">
                                    <span t-field="o.discount_amt_line"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </xpath>
        </template>
    </data>
</odoo>
