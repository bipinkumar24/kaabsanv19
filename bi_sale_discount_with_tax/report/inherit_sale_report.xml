<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_sale_discount_inherit" inherit_id="sale.report_saleorder_document">
            <xpath expr="//t[@t-set='display_discount']" position="attributes">
                <attribute name="t-value">any(l.discount for l in lines_to_report) or doc.discount_type == 'line'</attribute>
            </xpath>

            <xpath expr="//div[@id='informations']" position="inside">
                <div t-if="doc.discount_type" class="col" name="discount_type">
                    <strong>Discount Type</strong>
                    <div t-field="doc.discount_type"/>
                </div>
            </xpath>

            <xpath expr="//th[@name='th_discount']" position="replace">
                <th name="th_discount" t-if="display_discount" class="text-end">
                    <span t-if="doc.discount_type == 'line'">Discount</span>
                    <span t-else="">Disc.%</span>
                </th>
            </xpath>

            <xpath expr="//td[@name='td_product_discount']" position="replace">
                <td t-if="display_discount" name="td_product_discount" class="text-end">
                    <t t-if="not collapse_prices">
                        <t t-if="doc.discount_type == 'line'">
                            <t t-if="line.discount_amount">
                                <span t-field="line.discount_method"/>
                                <span t-field="line.discount_amount"/>
                                <span t-if="line.discount_method == 'per'">%</span>
                            </t>
                            <span t-else="">-</span>
                        </t>
                        <span t-else="" t-field="line.discount">-</span>
                    </t>
                </td>
            </xpath>

            <xpath expr="//div[@id='total']" position="after">
                <div t-if="doc.discount_type" class="row mt-2" name="discount_summary">
                    <div t-attf-class="#{'col-6' if report_type != 'html' else 'col-sm-7 col-md-6'} ms-auto">
                        <table class="table table-sm table-borderless">
                            <tr t-if="doc.discount_type == 'global'">
                                <td>Discount Method</td>
                                <td class="text-end">
                                    <span t-field="doc.discount_method"/>
                                </td>
                            </tr>
                            <tr t-if="doc.discount_type == 'global'">
                                <td>Discount Amount</td>
                                <td class="text-end">
                                    <span t-field="doc.discount_amount"/>
                                    <span t-if="doc.discount_method == 'per'">%</span>
                                </td>
                            </tr>
                            <tr t-if="doc.discount_type == 'global'">
                                <td>Discount</td>
                                <td class="text-end">
                                    <span t-field="doc.discount_amt"/>
                                </td>
                            </tr>
                            <tr t-if="doc.discount_type == 'line'">
                                <td>Line Discount</td>
                                <td class="text-end">
                                    <span t-field="doc.discount_amt_line"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </xpath>
        </template>
    </data>
</odoo>
