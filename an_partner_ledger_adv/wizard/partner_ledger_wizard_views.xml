<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Partner Ledger Wizard Form View -->
    <record id="view_partner_ledger_wizard_form" model="ir.ui.view">
        <field name="name">partner.ledger.wizard.form</field>
        <field name="model">partner.ledger.wizard</field>
        <field name="arch" type="xml">
            <form string="Partner Ledger Report">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="journal_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    </group>
                    <group>
                        <field name="partner_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        <field name="partner_category_ids" widget="many2many_tags" options="{'no_create': True}"/>
                        <field name="user_id" options="{'no_create': True}"/>
                    </group>
                </group>
                <group>
                    <group string="Options">
                        <field name="include_reconciled"/>
                        <field name="only_with_movement"/>
                        <field name="show_details"/>
                        <field name="summary_by_salesperson" invisible="not user_id"/>
                        <field name="balance_confirmation"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print_pdf" string="Print PDF" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Partner Ledger Report Action -->
    <record id="action_partner_ledger_wizard" model="ir.actions.act_window">
        <field name="name">Partner Ledger</field>
        <field name="res_model">partner.ledger.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_partner_ledger_report"
              name="Partner Ledger"
              parent="account.menu_finance_reports"
              action="action_partner_ledger_wizard"
              sequence="15"/>
</odoo>
